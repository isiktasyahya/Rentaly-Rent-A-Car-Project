@model Rentaly.EntityLayer.Entities.Category
@{
    ViewData["Title"] = "Yeni Kategori";
    ViewData["PageTitle"] = "Yeni Kategori Ekle";
    ViewData["BreadcrumbParent"] = "Kategori Yönetimi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <style>
        .create-layout {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 22px;
            align-items: start;
        }

        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.02em;
            line-height: 1.2;
        }

        .page-desc {
            font-size: 13.5px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .form-card {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        .form-card-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--card-border);
            display: flex;
            align-items: center;
            gap: 14px;
            background: linear-gradient(135deg, var(--accent-lighter) 0%, var(--card-bg) 65%);
        }

        .form-card-header-icon {
            width: 46px;
            height: 46px;
            border-radius: var(--radius);
            background: var(--accent-lighter);
            border: 1.5px solid #c7d2fe;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: var(--accent);
            flex-shrink: 0;
        }

        .form-card-title {
            font-family: var(--font-display);
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .form-card-subtitle {
            font-size: 12.5px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .form-card-body {
            padding: 28px 24px;
            display: flex;
            flex-direction: column;
            gap: 22px;
        }

        .form-section-label {
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: -8px;
        }

            .form-section-label::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--card-border);
            }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .form-label {
            font-family: var(--font-display);
            font-size: 12.5px;
            font-weight: 700;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .lbl-ico {
            font-size: 12px;
            color: var(--accent);
            width: 16px;
            text-align: center;
        }

        .required-dot {
            width: 6px;
            height: 6px;
            background: var(--rose);
            border-radius: 50%;
            display: inline-block;
            margin-left: 2px;
            flex-shrink: 0;
        }

        .input-wrap {
            position: relative;
        }

        .input-prefix {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 13px;
            pointer-events: none;
            transition: color var(--t-s);
        }

        .input-wrap:focus-within .input-prefix {
            color: var(--accent);
        }

        .form-input {
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-sm);
            padding: 10px 14px 10px 38px;
            font-size: 13.5px;
            font-family: var(--font-body);
            color: var(--text-primary);
            background: var(--page-bg);
            outline: none;
            transition: all var(--t-s);
            width: 100%;
        }

            .form-input:focus {
                border-color: var(--accent);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(79,70,229,0.10);
            }

            .form-input::placeholder {
                color: var(--text-muted);
            }

            .form-input.input-validation-error {
                border-color: var(--rose);
            }

        .char-counter {
            font-size: 11.5px;
            color: var(--text-muted);
            text-align: right;
            margin-top: -4px;
        }

            .char-counter.warn {
                color: var(--amber);
            }

            .char-counter.danger {
                color: var(--rose);
            }

        .field-error {
            font-size: 12px;
            color: var(--rose);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .field-hint {
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .form-divider {
            border: none;
            border-top: 1px dashed var(--card-border);
            margin: 2px 0;
        }

        /* ── Renk radio ── */
        .color-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-top: 4px;
        }

        .color-radio {
            display: none;
        }

        .color-lbl {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            padding: 10px 6px;
            border-radius: var(--radius);
            border: 1.5px solid var(--card-border);
            cursor: pointer;
            transition: all var(--t-s);
            background: var(--page-bg);
        }

            .color-lbl:hover {
                border-color: #c7d2fe;
                background: var(--accent-lighter);
            }

        .color-radio:checked + .color-lbl {
            border-color: var(--accent);
            background: var(--accent-lighter);
            box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
        }

        .color-swatch {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid rgba(0,0,0,0.08);
        }

        .color-txt {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 600;
        }

        /* ── İkon radio ── */
        .icon-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
            margin-top: 4px;
        }

        .icon-radio {
            display: none;
        }

        .icon-lbl {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 42px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--card-border);
            cursor: pointer;
            transition: all var(--t-s);
            background: var(--page-bg);
            font-size: 17px;
            color: var(--text-muted);
        }

            .icon-lbl:hover {
                border-color: #c7d2fe;
                background: var(--accent-lighter);
                color: var(--accent);
            }

        .icon-radio:checked + .icon-lbl {
            border-color: var(--accent);
            background: var(--accent-lighter);
            color: var(--accent);
            box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
        }

        /* ── Form footer ── */
        .form-card-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--card-border);
            background: #fafbff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-submit {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 11px 26px;
            font-size: 13.5px;
            font-weight: 700;
            font-family: var(--font-display);
            cursor: pointer;
            transition: all var(--t-s);
            box-shadow: 0 2px 8px rgba(79,70,229,0.25);
        }

            .btn-submit:hover {
                background: var(--accent-hover);
                transform: translateY(-1px);
                box-shadow: 0 4px 16px rgba(79,70,229,0.35);
            }

            .btn-submit:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                transform: none;
            }

        .btn-cancel-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            border-radius: var(--radius-sm);
            padding: 10px 16px;
            border: 1.5px solid var(--card-border);
            background: var(--card-bg);
            transition: all var(--t-s);
        }

            .btn-cancel-link:hover {
                border-color: #c7d2fe;
                color: var(--accent);
                background: var(--accent-lighter);
            }

        /* ── Right Panel ── */
        .info-panel {
            display: flex;
            flex-direction: column;
            gap: 16px;
            position: sticky;
            top: 24px;
        }

        .info-card {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        .info-card-header {
            padding: 13px 18px;
            border-bottom: 1px solid var(--card-border);
            display: flex;
            align-items: center;
            gap: 9px;
            background: #fafbff;
        }

            .info-card-header i {
                font-size: 13px;
                color: var(--accent);
            }

        .info-card-title {
            font-family: var(--font-display);
            font-size: 13px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .info-card-body {
            padding: 16px 18px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* Preview */
        .preview-cat {
            background: linear-gradient(135deg, var(--accent-lighter) 0%, #eef2ff 100%);
            border: 1.5px dashed #c7d2fe;
            border-radius: var(--radius);
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            transition: all var(--t);
            text-align: center;
        }

            .preview-cat.has-data {
                border-style: solid;
                border-color: var(--accent);
            }

        .preview-cat-icon {
            width: 56px;
            height: 56px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            transition: all var(--t-s);
            background: var(--accent-lighter);
            color: var(--accent);
            border: 1.5px solid #c7d2fe;
        }

        .preview-cat-name {
            font-family: var(--font-display);
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
        }

            .preview-cat-name.placeholder {
                color: var(--text-muted);
                font-weight: 400;
                font-style: italic;
                font-family: var(--font-body);
                font-size: 13px;
            }

        .preview-cat-badge {
            display: inline-flex;
            background: var(--accent-lighter);
            color: var(--accent-text);
            border: 1px solid #c7d2fe;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 99px;
        }

        /* Tips */
        .tip-item {
            display: flex;
            gap: 10px;
            align-items: flex-start;
        }

        .tip-dot {
            width: 24px;
            height: 24px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            flex-shrink: 0;
            margin-top: 1px;
        }

            .tip-dot.blue {
                background: var(--accent-lighter);
                color: var(--accent);
            }

            .tip-dot.green {
                background: #d1fae5;
                color: #059669;
            }

            .tip-dot.amber {
                background: #fef3c7;
                color: #d97706;
            }

        .tip-text {
            font-size: 12.5px;
            color: var(--text-muted);
            line-height: 1.5;
        }

            .tip-text strong {
                color: var(--text-secondary);
                font-weight: 700;
            }

        .required-note {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius);
            padding: 12px 16px;
            font-size: 12.5px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        @@media (max-width: 900px) {
            .create-layout {
                grid-template-columns: 1fr;
            }

            .info-panel {
                position: static;
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Kategori Ekle</h1>
        <p class="page-desc">Araç filomuna yeni bir kategori tanımlayın.</p>
    </div>
    <a href="/Category/Index" class="btn-cancel-link">
        <i class="fa-solid fa-arrow-left"></i> Kategori Listesi
    </a>
</div>

<div class="create-layout">

    <!-- ════ Sol: Form ════ -->
    <div>
        <form method="post" id="categoryForm" asp-action="Create" asp-controller="Category" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-header-icon"><i class="fa-solid fa-tags"></i></div>
                    <div>
                        <div class="form-card-title">Kategori Bilgileri</div>
                        <div class="form-card-subtitle">Aşağıdaki alanları doldurun.</div>
                    </div>
                </div>

                <div class="form-card-body">

                    <div class="form-section-label">
                        <i class="fa-solid fa-circle-info" style="font-size:10px;color:var(--accent);"></i>
                        Temel Bilgiler
                    </div>

                    <!-- ── CategoryName ── -->
                    <div class="form-group">
                        <label class="form-label" for="CategoryName">
                            <i class="lbl-ico fa-solid fa-tag"></i>
                            Kategori Adı
                            <span class="required-dot"></span>
                        </label>
                        <div class="input-wrap">
                            <input asp-for="CategoryName"
                                   class="form-input"
                                   placeholder="ör. Sedan, SUV, Elektrikli…"
                                   maxlength="50"
                                   oninput="updatePreview(); countChars(this,'nameCounter',50)"
                                   autocomplete="off" />
                            <i class="input-prefix fa-solid fa-tag"></i>
                        </div>
                        <div class="char-counter" id="nameCounter">0 / 50</div>
                        <span asp-validation-for="CategoryName" class="field-error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Araç tipini net tanımlayan kısa bir isim girin.
                        </span>
                    </div>

                    <hr class="form-divider" />

                    <div class="form-section-label">
                        <i class="fa-solid fa-palette" style="font-size:10px;color:var(--accent);"></i>
                        Görsel Ayarlar
                    </div>

                    <!-- ── ColorTag ── -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="lbl-ico fa-solid fa-droplet"></i>
                            Renk Etiketi
                        </label>
                        <div class="color-grid">
                            @{
                                var colorOpts = new[]
                                {
                                    ("#4f46e5", "İndigo"),
                                    ("#059669", "Yeşil"),
                                    ("#d97706", "Amber"),
                                    ("#e11d48", "Kırmızı"),
                                    ("#9333ea", "Mor"),
                                    ("#0284c7", "Mavi"),
                                    ("#db2777", "Pembe"),
                                    ("#ea580c", "Turuncu"),
                                };
                            }
                            @foreach (var (hex, label) in colorOpts)
                            {
                                var cid = "clr_" + hex.Replace("#", "");
                                <div>
                                    <input asp-for="ColorTag"
                                           type="radio"
                                           id="@cid"
                                           value="@hex"
                                           class="color-radio"
                                           onchange="updatePreview()" />
                                    <label for="@cid" class="color-lbl" title="@label">
                                        <div class="color-swatch" style="background:@hex;"></div>
                                        <span class="color-txt">@label</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <span class="field-hint" style="margin-top:2px;">
                            <i class="fa-solid fa-circle-info"></i>
                            Hex değeri (ör. #4f46e5) veritabanına kaydedilir.
                        </span>
                    </div>

                    <!-- ── CategoryIcon ── -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="lbl-ico fa-solid fa-icons"></i>
                            Kategori İkonu
                        </label>
                        <div class="icon-grid">
                            @{
                                var iconOpts = new[]
                                {
                                    ("fa-car-side",    "Araba"),
                                    ("fa-truck",       "Kamyon"),
                                    ("fa-motorcycle",  "Motor"),
                                    ("fa-van-shuttle", "Minivan"),
                                    ("fa-bus",         "Otobüs"),
                                    ("fa-car-rear",    "Sedan"),
                                    ("fa-taxi",        "Taksi"),
                                    ("fa-jeep",        "Jip"),
                                    ("fa-car",         "Araç"),
                                    ("fa-bolt",        "Elektrik"),
                                };
                            }
                            @foreach (var (ico, lbl) in iconOpts)
                            {
                                var iid = "ico_" + ico.Replace("fa-", "");
                                <div>
                                    <input asp-for="CategoryIcon"
                                           type="radio"
                                           id="@iid"
                                           value="@ico"
                                           class="icon-radio"
                                           onchange="updatePreview()" />
                                    <label for="@iid" class="icon-lbl" title="@lbl">
                                        <i class="fa-solid @ico"></i>
                                    </label>
                                </div>
                            }
                        </div>
                        <span class="field-hint" style="margin-top:2px;">
                            <i class="fa-solid fa-circle-info"></i>
                            İkon class adı (ör. fa-car-side) veritabanına kaydedilir.
                        </span>
                    </div>

                </div>

                <div class="form-card-footer">
                    <a href="/Category/Index" class="btn-cancel-link">
                        <i class="fa-solid fa-xmark"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Kategoriyi Kaydet
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- ════ Sağ: Panel ════ -->
    <div class="info-panel">

        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-eye"></i>
                <div class="info-card-title">Canlı Önizleme</div>
            </div>
            <div class="info-card-body">
                <div class="preview-cat" id="previewCard">
                    <div class="preview-cat-icon" id="previewIcon">
                        <i class="fa-solid fa-tags" id="previewIconEl"></i>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                        <div class="preview-cat-name placeholder" id="previewName">Kategori adı girilmedi…</div>
                        <span class="preview-cat-badge" id="previewBadge">Yeni Kategori</span>
                    </div>
                </div>
                <p style="font-size:11.5px;color:var(--text-muted);text-align:center;margin:0;">
                    Formu doldurdukça önizleme güncellenir.
                </p>
            </div>
        </div>

        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-lightbulb"></i>
                <div class="info-card-title">İpuçları</div>
            </div>
            <div class="info-card-body">
                <div class="tip-item">
                    <div class="tip-dot blue"><i class="fa-solid fa-tag"></i></div>
                    <div class="tip-text"><strong>Kategori Adı</strong> kısa ve araç tipini net yansıtmalı. "SUV", "Elektrikli" gibi.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot green"><i class="fa-solid fa-droplet"></i></div>
                    <div class="tip-text"><strong>Renk</strong> — hex değeri DB'ye kaydedilir, listede kategoriyi renklendirir.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot amber"><i class="fa-solid fa-icons"></i></div>
                    <div class="tip-text"><strong>İkon</strong> — class adı DB'ye kaydedilir, listede kategori ikonu olarak gösterilir.</div>
                </div>
            </div>
        </div>

        <div class="required-note">
            <span class="required-dot"></span>
            işaretli alanlar zorunludur.
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function updatePreview() {
            const name = document.getElementById('CategoryName').value.trim();
            const color = document.querySelector('.color-radio:checked')?.value || '#4f46e5';
            const icon = document.querySelector('.icon-radio:checked')?.value || 'fa-tags';

            const card = document.getElementById('previewCard');
            const pIcon = document.getElementById('previewIcon');
            const pIconEl = document.getElementById('previewIconEl');
            const pName = document.getElementById('previewName');
            const pBadge = document.getElementById('previewBadge');

            const hasData = !!(name || document.querySelector('.color-radio:checked') || document.querySelector('.icon-radio:checked'));
            card.classList.toggle('has-data', hasData);

            pIcon.style.background = color + '22';
            pIcon.style.color = color;
            pIcon.style.borderColor = color + '55';
            pIconEl.className = 'fa-solid ' + icon;

            if (name) {
                pName.textContent = name;
                pName.classList.remove('placeholder');
                pBadge.textContent = name;
            } else {
                pName.textContent = 'Kategori adı girilmedi…';
                pName.classList.add('placeholder');
                pBadge.textContent = 'Yeni Kategori';
            }

            pBadge.style.background = color + '22';
            pBadge.style.color = color;
            pBadge.style.borderColor = color + '55';
        }

        function countChars(el, counterId, max) {
            const len = el.value.length;
            const c = document.getElementById(counterId);
            c.textContent = len + ' / ' + max;
            c.className = 'char-counter';
            if (len > max * 0.75) c.classList.add('warn');
            if (len > max * 0.90) c.classList.add('danger');
        }

        document.getElementById('categoryForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
        });

        document.addEventListener('DOMContentLoaded', () => {
            updatePreview();
            const nameEl = document.getElementById('CategoryName');
            if (nameEl && nameEl.value) countChars(nameEl, 'nameCounter', 50);
        });
    </script>
}
