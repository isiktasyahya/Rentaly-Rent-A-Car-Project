@model Rentaly.EntityLayer.Entities.Faq
@{
    ViewData["Title"] = "CreateFaq";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}



@section Styles {
    <style>
        /* ══════════════════════════════════════════
           FAQ CREATE — Indigo Daylight Theme
        ══════════════════════════════════════════ */

        .create-layout {
            display: grid;
            grid-template-columns: 1fr 310px;
            gap: 22px;
            align-items: start;
        }

        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.02em;
            line-height: 1.2;
        }

        .page-desc {
            font-size: 13.5px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .form-card {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        .form-card-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--card-border);
            display: flex;
            align-items: center;
            gap: 14px;
            background: linear-gradient(135deg,var(--accent-lighter) 0%,var(--card-bg) 65%);
        }

        .form-card-header-icon {
            width: 46px;
            height: 46px;
            border-radius: var(--radius);
            background: var(--accent-lighter);
            border: 1.5px solid #c7d2fe;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: var(--accent);
            flex-shrink: 0;
        }

        .form-card-title {
            font-family: var(--font-display);
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .form-card-subtitle {
            font-size: 12.5px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .form-card-body {
            padding: 28px 24px;
            display: flex;
            flex-direction: column;
            gap: 22px;
        }

        .section-label {
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: -8px;
        }

            .section-label::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--card-border);
            }

        .f-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .f-label {
            font-family: var(--font-display);
            font-size: 12.5px;
            font-weight: 700;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .f-lbl-ico {
            font-size: 12px;
            color: var(--accent);
            width: 16px;
            text-align: center;
            transition: color var(--t-s);
        }

        .required-dot {
            width: 6px;
            height: 6px;
            background: var(--rose);
            border-radius: 50%;
            display: inline-block;
            margin-left: 2px;
            flex-shrink: 0;
        }

        .f-wrap {
            position: relative;
        }

        .f-ico {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 13px;
            pointer-events: none;
            transition: color var(--t-s);
        }

            .f-ico.top {
                top: 13px;
                transform: none;
            }

        .f-wrap:focus-within .f-ico {
            color: var(--accent);
        }

        .f-input {
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-sm);
            padding: 10px 14px 10px 38px;
            font-size: 13.5px;
            font-family: var(--font-body);
            color: var(--text-primary);
            background: var(--page-bg);
            outline: none;
            transition: all var(--t-s);
            width: 100%;
        }

            .f-input:focus {
                border-color: var(--accent);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(79,70,229,0.10);
            }

            .f-input::placeholder {
                color: var(--text-muted);
            }

            .f-input.input-validation-error {
                border-color: var(--rose);
            }

        textarea.f-input {
            resize: vertical;
            min-height: 140px;
            line-height: 1.75;
            padding-top: 12px;
        }

        .text-stats {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: -2px;
        }

        .t-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11.5px;
            color: var(--text-muted);
            background: var(--page-bg);
            border: 1px solid var(--card-border);
            padding: 4px 10px;
            border-radius: 99px;
            transition: all var(--t-s);
        }

            .t-pill.warn {
                border-color: #fde68a;
                color: #d97706;
                background: #fefce8;
            }

            .t-pill.danger {
                border-color: #fecdd3;
                color: #e11d48;
                background: #fff1f2;
            }

            .t-pill i {
                font-size: 10px;
            }

        .field-error {
            font-size: 12px;
            color: var(--rose);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .field-hint {
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .form-card-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--card-border);
            background: #fafbff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-submit {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 11px 26px;
            font-size: 13.5px;
            font-weight: 700;
            font-family: var(--font-display);
            cursor: pointer;
            transition: all var(--t-s);
            box-shadow: 0 2px 8px rgba(79,70,229,0.25);
        }

            .btn-submit:hover {
                background: var(--accent-hover);
                transform: translateY(-1px);
                box-shadow: 0 4px 16px rgba(79,70,229,0.35);
            }

            .btn-submit:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                transform: none;
            }

        .btn-cancel-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            border-radius: var(--radius-sm);
            padding: 10px 16px;
            border: 1.5px solid var(--card-border);
            background: var(--card-bg);
            transition: all var(--t-s);
        }

            .btn-cancel-link:hover {
                border-color: #c7d2fe;
                color: var(--accent);
                background: var(--accent-lighter);
            }

        /* Right Panel */
        .info-panel {
            display: flex;
            flex-direction: column;
            gap: 16px;
            position: sticky;
            top: 24px;
        }

        .info-card {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        .info-card-header {
            padding: 13px 18px;
            border-bottom: 1px solid var(--card-border);
            display: flex;
            align-items: center;
            gap: 9px;
            background: #fafbff;
        }

            .info-card-header i {
                font-size: 13px;
                color: var(--accent);
            }

        .info-card-title {
            font-family: var(--font-display);
            font-size: 13px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .info-card-body {
            padding: 16px 18px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* Canlı Önizleme — accordion */
        .preview-faq {
            background: var(--card-bg);
            border: 1.5px dashed #c7d2fe;
            border-radius: var(--radius);
            overflow: hidden;
            transition: all var(--t);
        }

            .preview-faq.has-data {
                border-style: solid;
                border-color: var(--accent);
                box-shadow: 0 4px 16px rgba(79,70,229,0.08);
            }

        .preview-faq-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            background: linear-gradient(135deg,var(--accent-lighter) 0%,var(--card-bg) 70%);
            transition: background var(--t-s);
        }

        .preview-num {
            width: 32px;
            height: 32px;
            border-radius: var(--radius-sm);
            background: var(--accent-lighter);
            color: var(--accent);
            border: 1.5px solid #c7d2fe;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 12px;
            font-weight: 800;
            flex-shrink: 0;
            transition: all var(--t-s);
        }

        .preview-faq.has-data .preview-num {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        .preview-q {
            font-family: var(--font-display);
            font-size: 13px;
            font-weight: 700;
            flex: 1;
            line-height: 1.3;
            color: var(--text-primary);
        }

            .preview-q.ph {
                color: var(--text-muted);
                font-style: italic;
                font-weight: 400;
                font-family: var(--font-body);
                font-size: 12.5px;
            }

        .preview-chevron {
            font-size: 10px;
            color: var(--accent);
        }

        .preview-faq-body {
            border-top: 1px solid var(--card-border);
            padding: 12px 16px 12px 58px;
        }

        .preview-a {
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.7;
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

            .preview-a.ph {
                color: var(--text-muted);
                font-style: italic;
            }

        /* Tips */
        .tip-item {
            display: flex;
            gap: 10px;
            align-items: flex-start;
        }

        .tip-dot {
            width: 24px;
            height: 24px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            flex-shrink: 0;
            margin-top: 1px;
        }

            .tip-dot.blue {
                background: var(--accent-lighter);
                color: var(--accent);
            }

            .tip-dot.green {
                background: #d1fae5;
                color: #059669;
            }

            .tip-dot.amber {
                background: #fef3c7;
                color: #d97706;
            }

        .tip-text {
            font-size: 12.5px;
            color: var(--text-muted);
            line-height: 1.5;
        }

            .tip-text strong {
                color: var(--text-secondary);
                font-weight: 700;
            }

        .required-note {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius);
            padding: 12px 16px;
            font-size: 12.5px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        @@media (max-width:900px) {
            .create-layout {
                grid-template-columns: 1fr;
            }

            .info-panel {
                position: static;
            }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Soru Ekle</h1>
        <p class="page-desc">SSS bölümüne yeni bir soru-cevap çifti ekleyin.</p>
    </div>
    <a href="/Faq/FaqList" class="btn-cancel-link">
        <i class="fa-solid fa-arrow-left"></i> Soru Listesi
    </a>
</div>

<div class="create-layout">

    <!-- Sol: Form -->
    <div>
        <form method="post" id="faqForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-header-icon">
                        <i class="fa-solid fa-circle-question"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Soru & Cevap</div>
                        <div class="form-card-subtitle">Aşağıdaki alanları eksiksiz doldurun.</div>
                    </div>
                </div>

                <div class="form-card-body">

                    <div class="section-label">
                        <i class="fa-solid fa-circle-question" style="font-size:10px;color:var(--accent);"></i>
                        Soru Bilgileri
                    </div>

                    <!-- Title (Soru) -->
                    <div class="f-group">
                        <label class="f-label" for="Title">
                            <i class="f-lbl-ico fa-solid fa-question"></i>
                            Soru
                            <span class="required-dot"></span>
                        </label>
                        <div class="f-wrap">
                            <input asp-for="Title"
                                   class="f-input"
                                   placeholder="ör. Araç teslim saatleri nelerdir?"
                                   maxlength="200"
                                   oninput="updatePreview(); countQ(this)"
                                   autocomplete="off" />
                            <i class="f-ico fa-solid fa-question"></i>
                        </div>
                        <div class="text-stats">
                            <span class="t-pill" id="titlePill">
                                <i class="fa-solid fa-font"></i>
                                <span id="titleCharCount">0</span> / 200 karakter
                            </span>
                        </div>
                        <span asp-validation-for="Title" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Soruyu müşteri perspektifinden, soru işaretiyle bitirerek yazın.
                        </span>
                    </div>

                    <!-- Description (Cevap) -->
                    <div class="f-group">
                        <label class="f-label" for="Description">
                            <i class="f-lbl-ico fa-solid fa-comment-dots"></i>
                            Cevap
                            <span class="required-dot"></span>
                        </label>
                        <div class="f-wrap">
                            <textarea asp-for="Description"
                                      class="f-input"
                                      rows="6"
                                      placeholder="ör. Araçlarımızı hafta içi 08:00-20:00, hafta sonu ise 09:00-18:00 saatleri arasında teslim alabilirsiniz…"
                                      maxlength="1000"
                                      oninput="updatePreview(); countA(this)"></textarea>
                            <i class="f-ico top fa-solid fa-comment-dots"></i>
                        </div>
                        <div class="text-stats">
                            <span class="t-pill" id="descCharPill">
                                <i class="fa-solid fa-font"></i>
                                <span id="descCharCount">0</span> / 1000 karakter
                            </span>
                            <span class="t-pill" id="descWordPill">
                                <i class="fa-solid fa-w"></i>
                                <span id="descWordCount">0</span> kelime
                            </span>
                        </div>
                        <span asp-validation-for="Description" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Açık, net ve anlaşılır bir cevap yazın. 30-100 kelime idealdir.
                        </span>
                    </div>

                </div>

                <div class="form-card-footer">
                    <a href="/Faq/FaqList" class="btn-cancel-link">
                        <i class="fa-solid fa-xmark"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Soruyu Kaydet
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Sağ: Panel -->
    <div class="info-panel">

        <!-- Canlı Önizleme -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-eye"></i>
                <div class="info-card-title">Canlı Önizleme</div>
            </div>
            <div class="info-card-body" style="padding:12px;">
                <div class="preview-faq" id="previewCard">
                    <div class="preview-faq-header">
                        <div class="preview-num">?</div>
                        <div class="preview-q ph" id="previewQ">Soru girilmedi…</div>
                        <i class="fa-solid fa-chevron-down preview-chevron"></i>
                    </div>
                    <div class="preview-faq-body">
                        <div class="preview-a ph" id="previewA">Cevap girilmedi…</div>
                    </div>
                </div>
                <p style="font-size:11px;color:var(--text-muted);text-align:center;margin:8px 0 0;">
                    Yazdıkça önizleme güncellenir.
                </p>
            </div>
        </div>

        <!-- İpuçları -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-lightbulb"></i>
                <div class="info-card-title">İyi Bir SSS İçin</div>
            </div>
            <div class="info-card-body">
                <div class="tip-item">
                    <div class="tip-dot blue"><i class="fa-solid fa-question"></i></div>
                    <div class="tip-text"><strong>Soru</strong> müşterilerin gerçekten sorduğu sorulardan seçilmeli.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot green"><i class="fa-solid fa-comment-dots"></i></div>
                    <div class="tip-text"><strong>Cevap</strong> kısa, net ve doğrudan olmalı. Uzun paragraflardan kaçının.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot amber"><i class="fa-solid fa-list-ol"></i></div>
                    <div class="tip-text">Sıralamanızı listeleme sayfasından istediğiniz gibi düzenleyebilirsiniz.</div>
                </div>
            </div>
        </div>

        <div class="required-note">
            <span class="required-dot"></span>
            işaretli alanlar zorunludur.
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function updatePreview() {
            const q = document.getElementById('Title').value.trim();
            const a = document.getElementById('Description').value.trim();

            const card = document.getElementById('previewCard');
            const pQ = document.getElementById('previewQ');
            const pA = document.getElementById('previewA');
            const pNum = document.querySelector('.preview-num');

            card.classList.toggle('has-data', !!(q || a));
            pNum.textContent = q || a ? '#' : '?';

            if (q) { pQ.textContent = q; pQ.classList.remove('ph'); }
            else { pQ.textContent = 'Soru girilmedi…'; pQ.classList.add('ph'); }

            if (a) {
                pA.textContent = a.length > 180 ? a.substring(0, 177) + '…' : a;
                pA.classList.remove('ph');
            } else {
                pA.textContent = 'Cevap girilmedi…';
                pA.classList.add('ph');
            }
        }

        function countQ(el) {
            const len = el.value.length;
            const pill = document.getElementById('titlePill');
            document.getElementById('titleCharCount').textContent = len;
            pill.className = 't-pill' + (len > 160 ? ' warn' : '') + (len > 190 ? ' danger' : '');
        }

        function countA(el) {
            const len = el.value.length;
            const words = el.value.trim() ? el.value.trim().split(/\s+/).filter(Boolean).length : 0;
            document.getElementById('descCharCount').textContent = len;
            document.getElementById('descWordCount').textContent = words;
            document.getElementById('descCharPill').className = 't-pill' + (len > 800 ? ' warn' : '') + (len > 950 ? ' danger' : '');
            document.getElementById('descWordPill').className = 't-pill' + (words > 80 ? ' warn' : '') + (words > 110 ? ' danger' : '');
        }

        document.getElementById('faqForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
        });

        document.querySelectorAll('.f-input').forEach(input => {
            input.addEventListener('focus', () => {
                const ico = input.closest('.f-group')?.querySelector('.f-lbl-ico');
                if (ico) ico.style.color = 'var(--accent)';
            });
            input.addEventListener('blur', () => {
                const ico = input.closest('.f-group')?.querySelector('.f-lbl-ico');
                if (ico) ico.style.color = '';
            });
        });

        document.addEventListener('DOMContentLoaded', () => {
            updatePreview();
            const titleEl = document.getElementById('Title');
            const descEl = document.getElementById('Description');
            if (titleEl?.value) countQ(titleEl);
            if (descEl?.value) countA(descEl);
        });</script>
}

