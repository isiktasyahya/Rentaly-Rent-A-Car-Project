
@{
    ViewData["Title"] = "CreateTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@model Rentaly.EntityLayer.Entities.Testimonial


@section Styles {
    <style>
            /* ══════════════════════════════════════════
           TESTIMONIAL CREATE — Indigo Daylight
        ══════════════════════════════════════════ */

            .create-layout {
                display: grid;
                grid-template-columns: 1fr 320px;
                gap: 22px;
                align-items: start;
            }

            .page-header {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 12px;
                margin-bottom: 24px;
            }

            .page-title {
                font-family: var(--font-display);
                font-size: 24px;
                font-weight: 700;
                color: var(--text-primary);
                letter-spacing: -0.02em;
                line-height: 1.2;
            }

            .page-desc {
                font-size: 13.5px;
                color: var(--text-muted);
                margin-top: 3px;
            }

            .form-card {
                background: var(--card-bg);
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius-lg);
                box-shadow: var(--card-shadow);
                overflow: hidden;
            }

            .form-card-header {
                padding: 20px 24px;
                border-bottom: 1px solid var(--card-border);
                display: flex;
                align-items: center;
                gap: 14px;
                background: linear-gradient(135deg,var(--accent-lighter) 0%,var(--card-bg) 65%);
            }

            .form-card-header-icon {
                width: 46px;
                height: 46px;
                border-radius: var(--radius);
                background: var(--accent-lighter);
                border: 1.5px solid #c7d2fe;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                color: var(--accent);
                flex-shrink: 0;
            }

            .form-card-title {
                font-family: var(--font-display);
                font-size: 15px;
                font-weight: 700;
                color: var(--text-primary);
            }

            .form-card-subtitle {
                font-size: 12.5px;
                color: var(--text-muted);
                margin-top: 2px;
            }

            .form-card-body {
                padding: 28px 24px;
                display: flex;
                flex-direction: column;
                gap: 22px;
            }

            .section-label {
                font-size: 10.5px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: -8px;
            }

                .section-label::after {
                    content: '';
                    flex: 1;
                    height: 1px;
                    background: var(--card-border);
                }

            .f-group {
                display: flex;
                flex-direction: column;
                gap: 7px;
            }

            .f-label {
                font-family: var(--font-display);
                font-size: 12.5px;
                font-weight: 700;
                color: var(--text-secondary);
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .f-lbl-ico {
                font-size: 12px;
                color: var(--accent);
                width: 16px;
                text-align: center;
                transition: color var(--t-s);
            }

            .required-dot {
                width: 6px;
                height: 6px;
                background: var(--rose);
                border-radius: 50%;
                display: inline-block;
                margin-left: 2px;
                flex-shrink: 0;
            }

            .f-wrap {
                position: relative;
            }

            .f-ico {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 13px;
                pointer-events: none;
                transition: color var(--t-s);
            }

                .f-ico.top {
                    top: 13px;
                    transform: none;
                }

            .f-wrap:focus-within .f-ico {
                color: var(--accent);
            }

            .f-input {
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius-sm);
                padding: 10px 14px 10px 38px;
                font-size: 13.5px;
                font-family: var(--font-body);
                color: var(--text-primary);
                background: var(--page-bg);
                outline: none;
                transition: all var(--t-s);
                width: 100%;
            }

                .f-input:focus {
                    border-color: var(--accent);
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(79,70,229,0.10);
                }

                .f-input::placeholder {
                    color: var(--text-muted);
                }

                .f-input.input-validation-error {
                    border-color: var(--rose);
                }

            textarea.f-input {
                resize: vertical;
                min-height: 110px;
                line-height: 1.65;
                padding-top: 11px;
            }

            /* ImageUrl — test butonu */
            .img-input-group {
                display: flex;
                gap: 8px;
            }

                .img-input-group .f-wrap {
                    flex: 1;
                }

            .btn-test {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 10px 14px;
                border-radius: var(--radius-sm);
                font-size: 13px;
                font-weight: 600;
                font-family: var(--font-body);
                background: var(--accent-lighter);
                color: var(--accent);
                border: 1.5px solid #c7d2fe;
                cursor: pointer;
                transition: all var(--t-s);
                white-space: nowrap;
                flex-shrink: 0;
            }

                .btn-test:hover {
                    background: var(--accent);
                    color: #fff;
                    border-color: var(--accent);
                }

            .char-counter {
                font-size: 11.5px;
                color: var(--text-muted);
                text-align: right;
                margin-top: -4px;
            }

                .char-counter.warn {
                    color: var(--amber);
                }

                .char-counter.danger {
                    color: var(--rose);
                }

            .field-error {
                font-size: 12px;
                color: var(--rose);
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .field-hint {
                font-size: 12px;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .form-divider {
                border: none;
                border-top: 1px dashed var(--card-border);
                margin: 2px 0;
            }

            .form-card-footer {
                padding: 16px 24px;
                border-top: 1px solid var(--card-border);
                background: #fafbff;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
                flex-wrap: wrap;
            }

            .btn-submit {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: var(--accent);
                color: #fff;
                border: none;
                border-radius: var(--radius-sm);
                padding: 11px 26px;
                font-size: 13.5px;
                font-weight: 700;
                font-family: var(--font-display);
                cursor: pointer;
                transition: all var(--t-s);
                box-shadow: 0 2px 8px rgba(79,70,229,0.25);
            }

                .btn-submit:hover {
                    background: var(--accent-hover);
                    transform: translateY(-1px);
                    box-shadow: 0 4px 16px rgba(79,70,229,0.35);
                }

                .btn-submit:disabled {
                    opacity: 0.7;
                    cursor: not-allowed;
                    transform: none;
                }

            .btn-cancel-link {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                color: var(--text-secondary);
                text-decoration: none;
                font-size: 13px;
                font-weight: 600;
                border-radius: var(--radius-sm);
                padding: 10px 16px;
                border: 1.5px solid var(--card-border);
                background: var(--card-bg);
                transition: all var(--t-s);
            }

                .btn-cancel-link:hover {
                    border-color: #c7d2fe;
                    color: var(--accent);
                    background: var(--accent-lighter);
                }

            /* Right Panel */
            .info-panel {
                display: flex;
                flex-direction: column;
                gap: 16px;
                position: sticky;
                top: 24px;
            }

            .info-card {
                background: var(--card-bg);
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius-lg);
                box-shadow: var(--card-shadow);
                overflow: hidden;
            }

            .info-card-header {
                padding: 13px 18px;
                border-bottom: 1px solid var(--card-border);
                display: flex;
                align-items: center;
                gap: 9px;
                background: #fafbff;
            }

                .info-card-header i {
                    font-size: 13px;
                    color: var(--accent);
                }

            .info-card-title {
                font-family: var(--font-display);
                font-size: 13px;
                font-weight: 700;
                color: var(--text-primary);
            }

            .info-card-body {
                padding: 16px 18px;
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

            /* Canlı Önizleme — yorum kartı */
            .preview-testi {
                background: linear-gradient(160deg, var(--accent-lighter) 0%, var(--card-bg) 45%);
                border: 1.5px dashed #c7d2fe;
                border-radius: var(--radius);
                overflow: hidden;
                transition: all var(--t);
            }

                .preview-testi.has-data {
                    border-style: solid;
                    border-color: var(--accent);
                    box-shadow: 0 4px 16px rgba(79,70,229,0.08);
                }

            .preview-body {
                padding: 18px 18px 14px;
                position: relative;
            }

            .preview-quote {
                position: absolute;
                top: 10px;
                right: 14px;
                font-size: 44px;
                line-height: 1;
                color: rgba(79,70,229,0.10);
                font-family: Georgia,serif;
            }

            .preview-stars {
                display: flex;
                gap: 3px;
                margin-bottom: 10px;
            }

                .preview-stars i {
                    font-size: 12px;
                    color: #f59e0b;
                }

            .preview-title {
                font-family: var(--font-display);
                font-size: 14px;
                font-weight: 700;
                color: var(--text-primary);
                margin-bottom: 8px;
                line-height: 1.3;
            }

                .preview-title.ph {
                    color: var(--text-muted);
                    font-style: italic;
                    font-weight: 400;
                    font-family: var(--font-body);
                    font-size: 13px;
                }

            .preview-desc {
                font-size: 12px;
                color: var(--text-secondary);
                line-height: 1.65;
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

                .preview-desc.ph {
                    color: var(--text-muted);
                    font-style: italic;
                }

            /* Avatar + isim footer */
            .preview-footer {
                padding: 12px 16px;
                border-top: 1px solid var(--card-border);
                background: var(--card-bg);
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .preview-avatar {
                width: 38px;
                height: 38px;
                border-radius: 50%;
                object-fit: cover;
                flex-shrink: 0;
                border: 2px solid var(--card-border);
            }

            .preview-avatar-ph {
                width: 38px;
                height: 38px;
                border-radius: 50%;
                background: var(--accent);
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: var(--font-display);
                font-size: 13px;
                font-weight: 700;
                flex-shrink: 0;
            }

            .preview-person-name {
                font-family: var(--font-display);
                font-size: 13px;
                font-weight: 700;
                color: var(--text-primary);
            }

                .preview-person-name.ph {
                    color: var(--text-muted);
                    font-style: italic;
                    font-weight: 400;
                }

            /* Tips */
            .tip-item {
                display: flex;
                gap: 10px;
                align-items: flex-start;
            }

            .tip-dot {
                width: 24px;
                height: 24px;
                border-radius: var(--radius-sm);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                flex-shrink: 0;
                margin-top: 1px;
            }

                .tip-dot.blue {
                    background: var(--accent-lighter);
                    color: var(--accent);
                }

                .tip-dot.green {
                    background: #d1fae5;
                    color: #059669;
                }

                .tip-dot.amber {
                    background: #fef3c7;
                    color: #d97706;
                }

                .tip-dot.rose {
                    background: #fff1f2;
                    color: #e11d48;
                }

            .tip-text {
                font-size: 12.5px;
                color: var(--text-muted);
                line-height: 1.5;
            }

                .tip-text strong {
                    color: var(--text-secondary);
                    font-weight: 700;
                }

            .required-note {
                background: var(--card-bg);
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius);
                padding: 12px 16px;
                font-size: 12.5px;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                gap: 8px;
            }

            @@media (max-width:900px) {
                .create-layout {
                    grid-template-columns: 1fr;
                }

                .info-panel {
                    position: static;
                }
            }
    </style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Müşteri Yorumu Ekle</h1>
        <p class="page-desc">Ana sayfada gösterilecek yeni bir müşteri yorumu ekleyin.</p>
    </div>
    <a href="/Testimonial/TestimonialList" class="btn-cancel-link">
        <i class="fa-solid fa-arrow-left"></i> Yorum Listesi
    </a>
</div>

<div class="create-layout">

    <!-- Sol: Form -->
    <div>
        <form method="post" id="testiForm" asp-action="CreateTestimonial" asp-controller="Testimonial" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-header-icon">
                        <i class="fa-solid fa-comments"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Yorum Bilgileri</div>
                        <div class="form-card-subtitle">Aşağıdaki alanları eksiksiz doldurun.</div>
                    </div>
                </div>

                <div class="form-card-body">

                    <div class="section-label">
                        <i class="fa-solid fa-user" style="font-size:10px;color:var(--accent);"></i>
                        Müşteri Bilgileri
                    </div>

                    <!-- NameSurname -->
                    <div class="f-group">
                        <label class="f-label" for="NameSurname">
                            <i class="f-lbl-ico fa-solid fa-user"></i>
                            Ad Soyad
                            <span class="required-dot"></span>
                        </label>
                        <div class="f-wrap">
                            <input asp-for="NameSurname"
                                   class="f-input"
                                   placeholder="ör. Ahmet Yılmaz"
                                   maxlength="80"
                                   oninput="updatePreview(); countChars(this,'nameCounter',80)"
                                   autocomplete="off" />
                            <i class="f-ico fa-solid fa-user"></i>
                        </div>
                        <div class="char-counter" id="nameCounter">0 / 80</div>
                        <span asp-validation-for="NameSurname" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                    </div>

                    <!-- ImageUrl -->
                    <div class="f-group">
                        <label class="f-label" for="ImageUrl">
                            <i class="f-lbl-ico fa-solid fa-image"></i>
                            Profil Fotoğrafı URL
                        </label>
                        <div class="img-input-group">
                            <div class="f-wrap">
                                <input asp-for="ImageUrl"
                                       class="f-input"
                                       placeholder="ör. /images/customers/ahmet.jpg"
                                       oninput="updatePreview()"
                                       autocomplete="off" />
                                <i class="f-ico fa-solid fa-image"></i>
                            </div>
                            <button type="button" class="btn-test" onclick="testImage()">
                                <i class="fa-solid fa-eye"></i> Test
                            </button>
                        </div>
                        <span asp-validation-for="ImageUrl" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            İsteğe bağlı — kare veya yuvarlak kırpılmış fotoğraf önerilir.
                        </span>

                        <div id="imgTestBox" style="display:none;margin-top:8px;padding:14px;background:var(--page-bg);border:1.5px solid var(--card-border);border-radius:var(--radius-sm);align-items:center;gap:12px;">
                            <img id="imgTestImg" src="" alt="Profil"
                                 style="width:44px;height:44px;object-fit:cover;border-radius:50%;border:2px solid var(--card-border);" />
                            <div>
                                <div style="font-size:12.5px;font-weight:600;color:var(--text-primary);">Fotoğraf Önizleme</div>
                                <div id="imgTestMsg" style="font-size:11.5px;color:var(--text-muted);">Yükleniyor…</div>
                            </div>
                        </div>
                    </div>

                    <hr class="form-divider" />

                    <div class="section-label">
                        <i class="fa-solid fa-comment" style="font-size:10px;color:var(--accent);"></i>
                        Yorum İçeriği
                    </div>

                    <!-- Title -->
                    <div class="f-group">
                        <label class="f-label" for="Title">
                            <i class="f-lbl-ico fa-solid fa-heading"></i>
                            Başlık
                            <span class="required-dot"></span>
                        </label>
                        <div class="f-wrap">
                            <input asp-for="Title"
                                   class="f-input"
                                   placeholder="ör. Harika Hizmet!, Kesinlikle Tavsiye Ederim…"
                                   maxlength="100"
                                   oninput="updatePreview(); countChars(this,'titleCounter',100)"
                                   autocomplete="off" />
                            <i class="f-ico fa-solid fa-heading"></i>
                        </div>
                        <div class="char-counter" id="titleCounter">0 / 100</div>
                        <span asp-validation-for="Title" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Yorumu özetleyen kısa bir başlık yazın.
                        </span>
                    </div>

                    <!-- Description -->
                    <div class="f-group">
                        <label class="f-label" for="Description">
                            <i class="f-lbl-ico fa-solid fa-align-left"></i>
                            Yorum
                            <span class="required-dot"></span>
                        </label>
                        <div class="f-wrap">
                            <textarea asp-for="Description"
                                      class="f-input"
                                      rows="5"
                                      placeholder="ör. Araç kiralama deneyimim mükemmeldi. Personel çok yardımsever, araç tertemizdi…"
                                      maxlength="600"
                                      oninput="updatePreview(); countChars(this,'descCounter',600)"></textarea>
                            <i class="f-ico top fa-solid fa-align-left"></i>
                        </div>
                        <div class="char-counter" id="descCounter">0 / 600</div>
                        <span asp-validation-for="Description" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Müşterinin samimi deneyimini yansıtmalı.
                        </span>
                    </div>

                </div>

                <div class="form-card-footer">
                    <a href="/Testimonial/TestimonialList" class="btn-cancel-link">
                        <i class="fa-solid fa-xmark"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Yorumu Kaydet
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Sağ: Panel -->
    <div class="info-panel">

        <!-- Canlı Önizleme -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-eye"></i>
                <div class="info-card-title">Canlı Önizleme</div>
            </div>
            <div class="info-card-body" style="padding:12px;">
                <div class="preview-testi" id="previewCard">

                    <div class="preview-body">
                        <div class="preview-quote">"</div>
                        <div class="preview-stars">
                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <div class="preview-title ph" id="previewTitle">Başlık girilmedi…</div>
                        <div class="preview-desc ph" id="previewDesc">Yorum girilmedi…</div>
                    </div>

                    <div class="preview-footer">
                        <div class="preview-avatar-ph" id="previewAvatarPh">?</div>
                        <img id="previewAvatarImg" src="" alt=""
                             class="preview-avatar" style="display:none;"
                             onerror="this.style.display='none'; document.getElementById('previewAvatarPh').style.display='flex';" />
                        <div>
                            <div class="preview-person-name ph" id="previewName">Ad girilmedi…</div>
                            <div style="font-size:10px;color:var(--accent);font-weight:700;background:var(--accent-lighter);border:1px solid #c7d2fe;padding:1px 7px;border-radius:99px;display:inline-block;margin-top:2px;"># Yeni</div>
                        </div>
                    </div>

                </div>
                <p style="font-size:11px;color:var(--text-muted);text-align:center;margin:8px 0 0;">
                    Formu doldurdukça önizleme güncellenir.
                </p>
            </div>
        </div>

        <!-- İpuçları -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-lightbulb"></i>
                <div class="info-card-title">İpuçları</div>
            </div>
            <div class="info-card-body">
                <div class="tip-item">
                    <div class="tip-dot blue"><i class="fa-solid fa-user"></i></div>
                    <div class="tip-text"><strong>Ad Soyad</strong> gerçek müşteri adı olmalı — güvenilirliği artırır.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot green"><i class="fa-solid fa-heading"></i></div>
                    <div class="tip-text"><strong>Başlık</strong> yorumun özeti gibi olmalı, dikkat çekici kısa bir ifade.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot amber"><i class="fa-solid fa-comment"></i></div>
                    <div class="tip-text"><strong>Yorum</strong> samimi ve özgün olmalı. 50-150 kelime idealdir.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot rose"><i class="fa-solid fa-image"></i></div>
                    <div class="tip-text"><strong>Fotoğraf</strong> opsiyoneldir. Kare oran (1:1) en iyi görünümü sağlar.</div>
                </div>
            </div>
        </div>

        <div class="required-note">
            <span class="required-dot"></span>
            işaretli alanlar zorunludur.
        </div>

    </div>
</div>

@section Scripts {
    <script>function updatePreview() {
        const name    = document.getElementById('NameSurname').value.trim();
        const title   = document.getElementById('Title').value.trim();
        const desc    = document.getElementById('Description').value.trim();
        const imgUrl  = document.getElementById('ImageUrl').value.trim();

        const card       = document.getElementById('previewCard');
        const pTitle     = document.getElementById('previewTitle');
        const pDesc      = document.getElementById('previewDesc');
        const pName      = document.getElementById('previewName');
        const pAvPh      = document.getElementById('previewAvatarPh');
        const pAvImg     = document.getElementById('previewAvatarImg');

        card.classList.toggle('has-data', !!(name || title || desc));

        // Başlık
        if (title) { pTitle.textContent = title; pTitle.classList.remove('ph'); }
        else        { pTitle.textContent = 'Başlık girilmedi…'; pTitle.classList.add('ph'); }

        // Açıklama
        if (desc) {
            pDesc.textContent = desc.length > 140 ? desc.substring(0,137)+'…' : desc;
            pDesc.classList.remove('ph');
        } else {
            pDesc.textContent = 'Yorum girilmedi…';
            pDesc.classList.add('ph');
        }

        // İsim + initials
        if (name) {
            pName.textContent = name;
            pName.classList.remove('ph');
            const parts = name.split(' ').filter(Boolean);
            const initials = parts.length >= 2
                ? (parts[0][0] + parts[parts.length-1][0]).toUpperCase()
                : name[0].toUpperCase();
            pAvPh.textContent = initials;
        } else {
            pName.textContent = 'Ad girilmedi…';
            pName.classList.add('ph');
            pAvPh.textContent = '?';
        }

        // Avatar
        if (imgUrl) {
            pAvImg.src = imgUrl;
            pAvImg.style.display = 'block';
            pAvPh.style.display  = 'none';
            pAvImg.onerror = () => { pAvImg.style.display = 'none'; pAvPh.style.display = 'flex'; };
        } else {
            pAvImg.style.display = 'none';
            pAvPh.style.display  = 'flex';
        }
    }

    function testImage() {
        const url = document.getElementById('ImageUrl').value.trim();
        const box = document.getElementById('imgTestBox');
        const img = document.getElementById('imgTestImg');
        const msg = document.getElementById('imgTestMsg');

        if (!url) { box.style.display = 'none'; return; }

        img.src = url;
        box.style.display = 'flex';
        msg.textContent = 'Yükleniyor…';
        msg.style.color = 'var(--text-muted)';

        img.onload  = () => { msg.textContent = 'Fotoğraf başarıyla yüklendi ✓'; msg.style.color = '#10b981'; };
        img.onerror = () => { msg.textContent = 'Fotoğraf yüklenemedi — URL\'yi kontrol edin.'; msg.style.color = '#f43f5e'; };
    }

    function countChars(el, counterId, max) {
        const len = el.value.length;
        const c   = document.getElementById(counterId);
        c.textContent = len + ' / ' + max;
        c.className   = 'char-counter';
        if (len > max * 0.80) c.classList.add('warn');
        if (len > max * 0.95) c.classList.add('danger');
    }

    document.getElementById('testiForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
    });

    document.querySelectorAll('.f-input').forEach(input => {
        input.addEventListener('focus', () => {
            const ico = input.closest('.f-group')?.querySelector('.f-lbl-ico');
            if (ico) ico.style.color = 'var(--accent)';
        });
        input.addEventListener('blur', () => {
            const ico = input.closest('.f-group')?.querySelector('.f-lbl-ico');
            if (ico) ico.style.color = '';
        });
    });

    document.addEventListener('DOMContentLoaded', () => {
        updatePreview();
        ['NameSurname','Title','Description'].forEach(id => {
            const el = document.getElementById(id);
            const maxMap = { NameSurname:80, Title:100, Description:600 };
            const ctrMap = { NameSurname:'nameCounter', Title:'titleCounter', Description:'descCounter' };
            if (el?.value) countChars(el, ctrMap[id], maxMap[id]);
        });
    });</script>
}


