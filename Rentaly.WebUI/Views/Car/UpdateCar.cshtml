                            </div>
                            <div class="f-group">
                                <label asp-for="VIN" class="f-label">
                                    <i class="fa-solid fa-barcode"></i> Şasi No (VIN)
                                </label>
                                <input asp-for="VIN" class="f-input"
                                       placeholder="WVWZZZ1JZ3W000001" maxlength="17"
                                       oninput="this.value=this.value.toUpperCase()" />
                                <span asp-validation-for="VIN" class="field-error">@*<i class="fa-solid fa-circle-exclamation"></i>*@</span>
                                <span class="f-hint"><i class="fa-solid fa-circle-info" style="color:var(--accent);font-size:10px;"></i> 17 karakterli araç kimlik numarası</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-card">
                    <div class="form-card-header">
                        <div class="section-icon" style="background:#fef3c7;color:#d97706;">
                            <i class="fa-solid fa-tags"></i>
