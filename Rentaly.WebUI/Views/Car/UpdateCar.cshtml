                                <label asp-for="PlateNumber" class="f-label">
                                    <i class="fa-solid fa-rectangle-list"></i> Plaka <span class="req">*</span>
                                </label>
                                <input asp-for="PlateNumber" class="f-input plate-input"
                                       placeholder="34 ABC 123" maxlength="15"
                                       oninput="this.value=this.value.toUpperCase(); updatePreview()" />
