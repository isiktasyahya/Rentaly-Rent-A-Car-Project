                                    <i class="fa-solid fa-copyright"></i> Marka <span class="req">*</span>
                                </label>
                                <select asp-for="BrandId" asp-items="ViewBag.Brands" class="f-input" onchange="updatePreview()">
                                    <option value="">— Marka Seçin —</option>
                                </select>
                                <span asp-validation-for="BrandId" class="field-error">@*<i class="fa-solid fa-circle-exclamation"></i>*@</span>
                            </div>
                            <div class="f-group">
