@section Scripts {
    <script>
        let currentStep = 1;
        const STEPS = 3;

        const stepHelpers = {
            1: {
                title: 'Adım 1 İpuçları',
                items: [
                    ['blue', 'fa-rectangle-list', '<strong>Plaka</strong> büyük harfle, Türk formatında girin: "34 ABC 123"'],
                    ['amber', 'fa-barcode', '<strong>VIN / Şasi No</strong> opsiyoneldir. Ruhsatta 17 haneli kod.'],
                    ['green', 'fa-tags', '<strong>Kategori & Şube</strong> araç filtrelemede kullanılır.'],
                ]
            },
            2: {
                title: 'Adım 2 İpuçları',
                items: [
                    ['blue', 'fa-calendar', '<strong>Yıl</strong> modeli doğru girin — filtrelemede gösterilir.'],
                    ['amber', 'fa-gauge-high', '<strong>Kilometre</strong> mevcut km durumunu yansıtmalı.'],
                    ['green', 'fa-image', '<strong>Görsel URL</strong> opsiyoneldir. Test butonuyla kontrol edin.'],
                ]
            },
            3: {
                title: 'Adım 3 İpuçları',
                items: [
                    ['blue', 'fa-turkish-lira-sign', '<strong>Günlük Fiyat</strong> müşteri arayüzünde gösterilecek ücrettir.'],
                    ['amber', 'fa-shield-halved', '<strong>Depozito</strong> rezervasyon sırasında alınacak güvence bedeli.'],
                    ['green', 'fa-toggle-on', '<strong>Aktif</strong> kapalıysa araç listede görünmez.'],
                ]
            }
        };

        function renderHelper(step) {
            const h = stepHelpers[step];
            document.getElementById('helperTitle').textContent = h.title;
            document.getElementById('helperBody').innerHTML = h.items.map(([cls, ico, txt]) => `
                <div class="helper-item">
                    <div class="helper-dot ${cls}"><i class="fa-solid ${ico}"></i></div>
                    <div class="helper-text">${txt}</div>
                </div>`).join('');
        }

        function goStep(step) {
            if (step < 1 || step > STEPS) return;

            // Eski adım
            document.getElementById(`sec-${currentStep}`).classList.remove('active');
            const oldTab = document.getElementById(`stab-${currentStep}`);
            oldTab.classList.remove('active');
            if (step > currentStep) {
                oldTab.classList.add('done');
                document.getElementById(`sbub-${currentStep}`).innerHTML = '<i class="fa-solid fa-check" style="font-size:10px;"></i>';
            } else {
                oldTab.classList.remove('done');
                document.getElementById(`sbub-${currentStep}`).textContent = currentStep;
            }

            currentStep = step;

            // Yeni adım
            document.getElementById(`sec-${currentStep}`).classList.add('active');
            const newTab = document.getElementById(`stab-${currentStep}`);
            newTab.classList.add('active');
            newTab.classList.remove('done');
            document.getElementById(`sbub-${currentStep}`).textContent = currentStep;

            // Progress
            const pct = Math.round((currentStep / STEPS) * 100);
            document.getElementById('progressFill').style.width = pct + '%';
            document.getElementById('progressPct').textContent = pct + '%';
            const labels = ['Temel Bilgiler', 'Araç Detayları', 'Fiyat & Durum'];
            document.getElementById('progressLabel').textContent = `Adım ${currentStep} / ${STEPS} — ${labels[currentStep - 1]}`;
            document.getElementById('stepMeta').textContent = `Adım ${currentStep} / ${STEPS}`;

            // Butonlar
            document.getElementById('btnPrev').style.display = currentStep > 1 ? '' : 'none';
            document.getElementById('btnNext').style.display = currentStep < STEPS ? '' : 'none';
            document.getElementById('btnSubmit').style.display = currentStep === STEPS ? '' : 'none';

            renderHelper(currentStep);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function nextStep() { goStep(currentStep + 1); }
        function prevStep() { goStep(currentStep - 1); }

        /* ── Canlı Önizleme ── */
        function updatePreview() {
            const plate = document.getElementById('PlateNumber')?.value?.toUpperCase() || '— — —';
            const year = document.getElementById('Year')?.value || '—';
            const km = document.getElementById('Kilometer')?.value;
            const fuel = document.getElementById('FuelType')?.value || '—';
            const seat = document.getElementById('SeatCount')?.value || '—';
            const bag = document.getElementById('LuggageCount')?.value || '—';
            const price = document.getElementById('DailyPrice')?.value;
            const imgUrl = document.getElementById('ImageUrl')?.value?.trim();

            const brandSel = document.getElementById('BrandId');
            const modSel = document.getElementById('CarModelId');
            const brandTxt = brandSel?.selectedIndex > 0 ? brandSel.options[brandSel.selectedIndex].text : '';
            const modTxt = modSel?.selectedIndex > 0 ? modSel.options[modSel.selectedIndex].text : '';

            const card = document.getElementById('previewCard');
            const pImg = document.getElementById('previewImgEl');
            const pPh = document.getElementById('previewImgPh');

            const hasData = !!(document.getElementById('PlateNumber')?.value ||
                document.getElementById('Year')?.value ||
                brandTxt);
            card.classList.toggle('has-data', hasData);

            // Plaka
            document.getElementById('previewPlate').textContent = plate || '— — —';

            // Başlık
            const title = [brandTxt, modTxt].filter(Boolean).join(' ');
            const pTitle = document.getElementById('previewTitle');
            pTitle.textContent = title || 'Araç bilgileri girilmedi…';
            pTitle.classList.toggle('ph', !title);

            // Meta
            document.getElementById('previewYear').textContent = year;
            document.getElementById('pc-km').textContent = km ? parseInt(km).toLocaleString('tr-TR') : '—';
            document.getElementById('pc-fuel').textContent = fuel || '—';
            document.getElementById('pc-seat').textContent = seat;
            document.getElementById('pc-bag').textContent = bag;

            // Fiyat
            document.getElementById('previewPrice').textContent = price
                ? parseFloat(price).toLocaleString('tr-TR', { minimumFractionDigits: 0 }) + ' ₺'
                : '— ₺';

            // Görsel
            if (imgUrl) {
                pImg.src = imgUrl;
                pImg.style.display = 'block';
                pPh.style.display = 'none';
                pImg.onerror = imgError;
            } else {
                pImg.style.display = 'none';
                pPh.style.display = 'block';
            }
        }

        function imgError() {
            document.getElementById('previewImgEl').style.display = 'none';
            document.getElementById('previewImgPh').style.display = 'block';
        }

        function testImage() {
            const url = document.getElementById('ImageUrl').value.trim();
            const box = document.getElementById('imgPreviewBox');
            const img = document.getElementById('imgPreviewEl');

            if (!url) { box.style.display = 'none'; return; }

            img.src = url;
            box.style.display = 'block';
            img.onload = () => { updatePreview(); };
            img.onerror = () => { box.style.display = 'none'; imgError(); };
        }

        function clearImage() {
            document.getElementById('ImageUrl').value = '';
            document.getElementById('imgPreviewBox').style.display = 'none';
            document.getElementById('previewImgEl').style.display = 'none';
            document.getElementById('previewImgPh').style.display = 'block';
        }

        document.getElementById('carForm').addEventListener('submit', function () {
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
        });

        document.addEventListener('DOMContentLoaded', () => {
            goStep(1);
            updatePreview();
        });
        document.getElementById('BrandId').addEventListener('change', function () {
            const brandId = this.value;
            const modelSelect = document.getElementById('CarModelId');

            // Önce temizle
            modelSelect.innerHTML = '<option value="">— Model Seçin —</option>';

            if (!brandId) return;

            // AJAX ile markaya ait modelleri çek
            fetch(`/Car/GetModelsByBrand?brandId=${brandId}`)
                .then(res => res.json())
                .then(data => {
                    data.forEach(m => {
                        const opt = document.createElement('option');
                        opt.value = m.carModelId;
                        opt.textContent = m.modelName;
                        modelSelect.appendChild(opt);
                    });
                });
        });
    </script>
}


