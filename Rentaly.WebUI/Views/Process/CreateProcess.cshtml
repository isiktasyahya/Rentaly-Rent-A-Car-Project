@model Rentaly.EntityLayer.Entities.Process
@{
    ViewData["Title"] = "CreateProcess";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


@section Styles {
    <style>
    /* ══════════════════════════════════════════
       PROCESS CREATE — Indigo Daylight Theme
    ══════════════════════════════════════════ */

    .create-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 22px;
        align-items: start;
    }

    /* ── Form Card ── */
    .form-card {
        background: var(--card-bg);
        border: 1.5px solid var(--card-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--card-shadow);
        overflow: hidden;
    }

    .form-card-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--card-border);
        display: flex;
        align-items: center;
        gap: 14px;
        background: linear-gradient(135deg, var(--accent-lighter) 0%, var(--card-bg) 65%);
    }

    .form-card-header-icon {
        width: 46px; height: 46px;
        border-radius: var(--radius);
        background: var(--accent-lighter);
        border: 1.5px solid #c7d2fe;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; color: var(--accent);
        flex-shrink: 0;
    }

    .form-card-title {
        font-family: var(--font-display);
        font-size: 15px; font-weight: 700;
        color: var(--text-primary); line-height: 1.2;
    }

    .form-card-subtitle { font-size: 12.5px; color: var(--text-muted); margin-top: 2px; }

    .form-card-body {
        padding: 28px 24px;
        display: flex; flex-direction: column; gap: 22px;
    }

    .form-section-label {
        font-size: 10.5px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.12em;
        color: var(--text-muted);
        display: flex; align-items: center; gap: 8px;
        margin-bottom: -8px;
    }

    .form-section-label::after {
        content: ''; flex: 1; height: 1px;
        background: var(--card-border);
    }

    .form-group { display: flex; flex-direction: column; gap: 7px; }

    .form-label {
        font-family: var(--font-display);
        font-size: 12.5px; font-weight: 700;
        color: var(--text-secondary);
        display: flex; align-items: center; gap: 6px;
    }

    .form-label i { font-size: 12px; color: var(--accent); width: 16px; text-align: center; }
    .required-dot { width: 6px; height: 6px; background: var(--rose); border-radius: 50%; display: inline-block; margin-left: 2px; }

    .input-icon-wrap { position: relative; }

    .input-icon {
        position: absolute; left: 13px; top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted); font-size: 13px;
        pointer-events: none; transition: color var(--t-s);
    }

    .input-icon.top { top: 13px; transform: none; }

    .form-input {
        border: 1.5px solid var(--card-border);
        border-radius: var(--radius-sm);
        padding: 10px 14px 10px 38px;
        font-size: 13.5px; font-family: var(--font-body);
        color: var(--text-primary); background: var(--page-bg);
        outline: none; transition: all var(--t-s); width: 100%;
    }

    .form-input:focus {
        border-color: var(--accent); background: #fff;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.10);
    }

    .input-icon-wrap:focus-within .input-icon { color: var(--accent); }

    .form-input::placeholder { color: var(--text-muted); }

    textarea.form-input {
        resize: vertical; min-height: 110px;
        line-height: 1.65; padding-top: 11px;
    }

    .field-error {
        font-size: 12px; color: var(--rose);
        display: flex; align-items: center; gap: 5px;
    }

    .field-hint {
        font-size: 12px; color: var(--text-muted);
        display: flex; align-items: center; gap: 5px;
    }

    .char-counter {
        font-size: 11.5px; color: var(--text-muted);
        text-align: right; margin-top: -4px;
        font-family: var(--font-body); transition: color var(--t-s);
    }

    .char-counter.warn   { color: var(--amber); }
    .char-counter.danger { color: var(--rose); }

    .form-divider { border: none; border-top: 1px dashed var(--card-border); margin: 2px 0; }

    /* ── Footer ── */
    .form-card-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--card-border);
        background: #fafbff;
        display: flex; align-items: center;
        justify-content: space-between;
        gap: 12px; flex-wrap: wrap;
    }

    .btn-submit {
        display: inline-flex; align-items: center; gap: 8px;
        background: var(--accent); color: #fff;
        border: none; border-radius: var(--radius-sm);
        padding: 11px 26px;
        font-size: 13.5px; font-weight: 700;
        font-family: var(--font-display);
        cursor: pointer; transition: all var(--t-s);
        box-shadow: 0 2px 8px rgba(79,70,229,0.25);
    }

    .btn-submit:hover {
        background: var(--accent-hover);
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(79,70,229,0.35);
    }

    .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

    .btn-cancel-link {
        display: inline-flex; align-items: center; gap: 6px;
        color: var(--text-secondary); text-decoration: none;
        font-size: 13px; font-weight: 600; font-family: var(--font-body);
        border-radius: var(--radius-sm); padding: 10px 16px;
        border: 1.5px solid var(--card-border);
        background: var(--card-bg); transition: all var(--t-s);
    }

    .btn-cancel-link:hover { border-color: #c7d2fe; color: var(--accent); background: var(--accent-lighter); }

    /* ══════════════════════════════════════════
       RIGHT PANEL
    ══════════════════════════════════════════ */
    .info-panel {
        display: flex; flex-direction: column;
        gap: 16px; position: sticky; top: 24px;
    }

    .info-card {
        background: var(--card-bg);
        border: 1.5px solid var(--card-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--card-shadow);
        overflow: hidden;
    }

    .info-card-header {
        padding: 13px 18px; border-bottom: 1px solid var(--card-border);
        display: flex; align-items: center; gap: 9px;
        background: #fafbff;
    }

    .info-card-header i { font-size: 13px; color: var(--accent); }

    .info-card-title {
        font-family: var(--font-display);
        font-size: 13px; font-weight: 700; color: var(--text-primary);
    }

    .info-card-body { padding: 16px 18px; display: flex; flex-direction: column; gap: 12px; }

    /* Live Preview — process card style */
    .preview-process {
        background: linear-gradient(135deg, var(--accent-lighter) 0%, #eef2ff 100%);
        border: 1.5px dashed #c7d2fe;
        border-radius: var(--radius);
        overflow: hidden;
        transition: all var(--t);
    }

    .preview-process.has-data {
        border-color: var(--accent);
        border-style: solid;
    }

    .preview-top {
        height: 56px;
        display: flex; align-items: center; justify-content: center;
        border-bottom: 1px solid rgba(199,210,254,0.5);
        position: relative;
    }

    .preview-step-num {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: var(--accent);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-family: var(--font-display);
        font-size: 14px; font-weight: 700;
        box-shadow: 0 2px 8px rgba(79,70,229,0.3);
        transition: all var(--t-s);
    }

    .preview-process.has-data .preview-step-num {
        box-shadow: 0 4px 14px rgba(79,70,229,0.4);
        transform: scale(1.05);
    }

    .preview-body { padding: 14px 16px; display: flex; flex-direction: column; gap: 6px; }

    .preview-title {
        font-family: var(--font-display);
        font-size: 13.5px; font-weight: 700;
        color: var(--text-primary); line-height: 1.3;
    }

    .preview-title.placeholder {
        color: var(--text-muted);
        font-weight: 400; font-style: italic;
        font-family: var(--font-body);
    }

    .preview-desc-text {
        font-size: 12px; color: var(--text-secondary);
        line-height: 1.55;
    }

    .preview-desc-text.placeholder { color: var(--text-muted); font-style: italic; }

    /* Tips */
    .tip-item { display: flex; gap: 10px; align-items: flex-start; }

    .tip-dot {
        width: 24px; height: 24px;
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; flex-shrink: 0; margin-top: 1px;
    }

    .tip-dot.blue   { background: var(--accent-lighter); color: var(--accent); }
    .tip-dot.green  { background: #d1fae5; color: #059669; }
    .tip-dot.amber  { background: #fef3c7; color: #d97706; }

    .tip-text { font-size: 12.5px; color: var(--text-muted); line-height: 1.5; }
    .tip-text strong { color: var(--text-secondary); font-weight: 700; }

    .required-note {
        background: var(--card-bg);
        border: 1.5px solid var(--card-border);
        border-radius: var(--radius);
        padding: 12px 16px;
        font-size: 12.5px; color: var(--text-muted);
        display: flex; align-items: center; gap: 8px;
    }

    /* page-header */
    .page-header {
        display: flex; align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap; gap: 12px; margin-bottom: 24px;
    }

    .page-title {
        font-family: var(--font-display);
        font-size: 24px; font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.02em; line-height: 1.2;
    }

    .page-desc { font-size: 13.5px; color: var(--text-muted); margin-top: 3px; }

    @@media (max-width: 900px) {
        .create-layout { grid-template-columns: 1fr; }
        .info-panel { position: static; }
    }
    </style>
}

<!-- ═══ Page Header ═══ -->
<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Adım Ekle</h1>
        <p class="page-desc">Müşteri akışına yeni bir süreç adımı ekleyin.</p>
    </div>
    <a href="/Process/Index" class="btn-cancel-link">
        <i class="fa-solid fa-arrow-left"></i> Adım Listesi
    </a>
</div>

<!-- ═══ Layout ═══ -->
<div class="create-layout">

    <!-- Sol: Form -->
    <div>
        <form method="post" id="processForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-header-icon">
                        <i class="fa-solid fa-layer-group"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Adım Bilgileri</div>
                        <div class="form-card-subtitle">Yeni süreci tanımlayan bilgileri girin.</div>
                    </div>
                </div>

                <div class="form-card-body">

                    <div class="form-section-label">
                        <i class="fa-solid fa-circle-info" style="font-size:10px;color:var(--accent);"></i>
                        Adım Detayları
                    </div>

                    <!-- Başlık -->
                    <div class="form-group">
                        <label class="form-label" for="ProcessTitle">
                            <i class="fa-solid fa-heading"></i>
                            Adım Başlığı
                            <span class="required-dot"></span>
                        </label>
                        <div class="input-icon-wrap">
                            <input asp-for="ProcessTitle"
                                   id="ProcessTitle"
                                   class="form-input"
                                   placeholder="ör. Aracı Seçin"
                                   maxlength="100"
                                   oninput="updatePreview(); countChars(this,'titleCounter',100)"
                                   autocomplete="off" />
                            <i class="input-icon fa-solid fa-heading"></i>
                        </div>
                        <div class="char-counter" id="titleCounter">0 / 100</div>
                        <span asp-validation-for="ProcessTitle" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Kısa, net ve aksiyon içeren bir başlık yazın.
                        </span>
                    </div>

                    <hr class="form-divider" />

                    <!-- Açıklama -->
                    <div class="form-group">
                        <label class="form-label" for="ProcessDescription">
                            <i class="fa-solid fa-align-left"></i>
                            Açıklama
                            <span class="required-dot"></span>
                        </label>
                        <div class="input-icon-wrap">
                            <textarea asp-for="ProcessDescription"
                                      id="ProcessDescription"
                                      class="form-input"
                                      rows="4"
                                      placeholder="ör. Araç tipini, tarihi ve lokasyonu seçerek başlayın."
                                      maxlength="500"
                                      oninput="updatePreview(); countChars(this,'descCounter',500)"></textarea>
                            <i class="input-icon top fa-solid fa-align-left"></i>
                        </div>
                        <div class="char-counter" id="descCounter">0 / 500</div>
                        <span asp-validation-for="ProcessDescription" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Müşteriye bu adımda ne yapacağını açıklayın.
                        </span>
                    </div>

                </div>

                <div class="form-card-footer">
                    <a href="/Process/Index" class="btn-cancel-link">
                        <i class="fa-solid fa-xmark"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Adımı Kaydet
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Sağ: Panel -->
    <div class="info-panel">

        <!-- Canlı Önizleme -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-eye"></i>
                <div class="info-card-title">Canlı Önizleme</div>
            </div>
            <div class="info-card-body">
                <div class="preview-process" id="previewCard">
                    <div class="preview-top">
                        <div class="preview-step-num">?</div>
                    </div>
                    <div class="preview-body">
                        <div class="preview-title placeholder" id="previewTitle">Başlık girilmedi…</div>
                        <div class="preview-desc-text placeholder" id="previewDesc">Açıklama girilmedi…</div>
                    </div>
                </div>
                <p style="font-size:11.5px;color:var(--text-muted);text-align:center;margin:0;">
                    Formu doldurdukça önizleme güncellenir.
                </p>
            </div>
        </div>

        <!-- İpuçları -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-lightbulb"></i>
                <div class="info-card-title">İpuçları</div>
            </div>
            <div class="info-card-body">
                <div class="tip-item">
                    <div class="tip-dot blue"><i class="fa-solid fa-heading"></i></div>
                    <div class="tip-text">
                        <strong>Başlık</strong> aksiyon fiili içermeli: "Aracı Seçin", "Rezervasyon Yapın" gibi.
                    </div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot green"><i class="fa-solid fa-align-left"></i></div>
                    <div class="tip-text">
                        <strong>Açıklama</strong> müşteriye bu adımda ne yapacağını 1-2 cümleyle anlatmalı.
                    </div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot amber"><i class="fa-solid fa-sort"></i></div>
                    <div class="tip-text">
                        Adımlar kayıt sırasına göre sıralanır. Sırayı listeden sonradan değiştirebilirsiniz.
                    </div>
                </div>
            </div>
        </div>

        <div class="required-note">
            <span class="required-dot"></span>
            işaretli alanlar zorunludur.
        </div>

    </div>
</div>

@section Scripts {
    <script>
    function updatePreview() {
            const title = document.getElementById('ProcessTitle').value.trim();
            const desc = document.getElementById('ProcessDescription').value.trim();

            const card = document.getElementById('previewCard');
            const pTitle = document.getElementById('previewTitle');
            const pDesc = document.getElementById('previewDesc');

            const hasData = title || desc;
            card.classList.toggle('has-data', !!hasData);

            if (title) {
                pTitle.textContent = title;
                pTitle.classList.remove('placeholder');
            } else {
                pTitle.textContent = 'Başlık girilmedi…';
                pTitle.classList.add('placeholder');
            }

            if (desc) {
                pDesc.textContent = desc.length > 90 ? desc.substring(0, 87) + '…' : desc;
                pDesc.classList.remove('placeholder');
            } else {
                pDesc.textContent = 'Açıklama girilmedi…';
                pDesc.classList.add('placeholder');
            }
        }

        function countChars(el, counterId, max) {
            const len = el.value.length;
            const counter = document.getElementById(counterId);
            counter.textContent = `${len} / ${max}`;
            counter.className = 'char-counter';
            if (len > max * 0.85) counter.classList.add('warn');
            if (len > max * 0.95) counter.classList.add('danger');
        }

        document.getElementById('processForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
        });

        document.querySelectorAll('.form-input').forEach(input => {
            input.addEventListener('focus', () => {
                const icon = input.closest('.form-group')?.querySelector('.form-label i');
                if (icon) icon.style.color = 'var(--accent)';
            });
            input.addEventListener('blur', () => {
                const icon = input.closest('.form-group')?.querySelector('.form-label i');
                if (icon) icon.style.color = '';
            });
        });

        document.addEventListener('DOMContentLoaded', () => {
            updatePreview();
            const titleEl = document.getElementById('ProcessTitle');
            const descEl = document.getElementById('ProcessDescription');
            if (titleEl.value) countChars(titleEl, 'titleCounter', 100);
            if (descEl.value) countChars(descEl, 'descCounter', 500);
        });</script>
}


