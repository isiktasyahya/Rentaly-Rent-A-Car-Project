@model Rentaly.EntityLayer.Entities.Branch
@{
    ViewData["Title"] = "UpdateBranch";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <style>
            /* ══════════════════════════════════════════
           BRANCH CREATE — Indigo Daylight Theme
        ══════════════════════════════════════════ */

            .create-layout {
                display: grid;
                grid-template-columns: 1fr 320px;
                gap: 22px;
                align-items: start;
            }

            /* ── Form Card ── */
            .form-card {
                background: var(--card-bg);
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius-lg);
                box-shadow: var(--card-shadow);
                overflow: hidden;
            }

            .form-card-header {
                padding: 20px 24px;
                border-bottom: 1px solid var(--card-border);
                display: flex;
                align-items: center;
                gap: 14px;
                background: linear-gradient(135deg, var(--accent-lighter) 0%, var(--card-bg) 65%);
            }

            .form-card-header-icon {
                width: 46px;
                height: 46px;
                border-radius: var(--radius);
                background: var(--accent-lighter);
                border: 1.5px solid #c7d2fe;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                color: var(--accent);
                flex-shrink: 0;
            }

            .form-card-title {
                font-family: var(--font-display);
                font-size: 15px;
                font-weight: 700;
                color: var(--text-primary);
                line-height: 1.2;
            }

            .form-card-subtitle {
                font-size: 12.5px;
                color: var(--text-muted);
                margin-top: 2px;
            }

            .form-card-body {
                padding: 28px 24px;
                display: flex;
                flex-direction: column;
                gap: 22px;
            }

            /* ── Section Label ── */
            .form-section-label {
                font-size: 10.5px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: -8px;
            }

                .form-section-label::after {
                    content: '';
                    flex: 1;
                    height: 1px;
                    background: var(--card-border);
                }

            /* ── Form Group ── */
            .form-group {
                display: flex;
                flex-direction: column;
                gap: 7px;
            }

            .form-label {
                font-family: var(--font-display);
                font-size: 12.5px;
                font-weight: 700;
                color: var(--text-secondary);
                display: flex;
                align-items: center;
                gap: 6px;
                letter-spacing: 0.01em;
            }

                .form-label i {
                    font-size: 12px;
                    color: var(--accent);
                    width: 16px;
                    text-align: center;
                }

            .required-dot {
                width: 6px;
                height: 6px;
                background: var(--rose);
                border-radius: 50%;
                display: inline-block;
                margin-left: 2px;
                flex-shrink: 0;
            }

            /* ── Input ── */
            .input-icon-wrap {
                position: relative;
            }

            .input-icon {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 13px;
                pointer-events: none;
                transition: color var(--t-s);
            }

                .input-icon.top {
                    top: 13px;
                    transform: none;
                }

            .form-input {
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius-sm);
                padding: 10px 14px 10px 38px;
                font-size: 13.5px;
                font-family: var(--font-body);
                color: var(--text-primary);
                background: var(--page-bg);
                outline: none;
                transition: all var(--t-s);
                width: 100%;
            }

                .form-input:focus {
                    border-color: var(--accent);
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(79,70,229,0.10);
                }

                    .form-input:focus + .input-icon,
                    .input-icon-wrap:focus-within .input-icon {
                        color: var(--accent);
                    }

                .form-input.is-invalid {
                    border-color: var(--rose);
                    background: #fff8f8;
                }

                    .form-input.is-invalid:focus {
                        box-shadow: 0 0 0 3px rgba(244,63,94,0.10);
                    }

                .form-input::placeholder {
                    color: var(--text-muted);
                }

            textarea.form-input {
                resize: vertical;
                min-height: 96px;
                line-height: 1.6;
                padding-top: 11px;
            }

            /* ── Validation & Hints ── */
            .field-error {
                font-size: 12px;
                color: var(--rose);
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .field-hint {
                font-size: 12px;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .char-counter {
                font-size: 11.5px;
                color: var(--text-muted);
                text-align: right;
                margin-top: -4px;
                font-family: var(--font-body);
                transition: color var(--t-s);
            }

                .char-counter.warn {
                    color: var(--amber);
                }

                .char-counter.danger {
                    color: var(--rose);
                }

            .form-divider {
                border: none;
                border-top: 1px dashed var(--card-border);
                margin: 2px 0;
            }

            /* ── Form Footer ── */
            .form-card-footer {
                padding: 16px 24px;
                border-top: 1px solid var(--card-border);
                background: #fafbff;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
                flex-wrap: wrap;
            }

            .btn-submit {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: var(--accent);
                color: #fff;
                border: none;
                border-radius: var(--radius-sm);
                padding: 11px 26px;
                font-size: 13.5px;
                font-weight: 700;
                font-family: var(--font-display);
                cursor: pointer;
                transition: all var(--t-s);
                box-shadow: 0 2px 8px rgba(79,70,229,0.25);
            }

                .btn-submit:hover {
                    background: var(--accent-hover);
                    transform: translateY(-1px);
                    box-shadow: 0 4px 16px rgba(79,70,229,0.35);
                }

                .btn-submit:active {
                    transform: translateY(0);
                }

                .btn-submit:disabled {
                    opacity: 0.7;
                    cursor: not-allowed;
                    transform: none;
                }

            .btn-cancel-link {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                color: var(--text-secondary);
                text-decoration: none;
                font-size: 13px;
                font-weight: 600;
                font-family: var(--font-body);
                border-radius: var(--radius-sm);
                padding: 10px 16px;
                border: 1.5px solid var(--card-border);
                background: var(--card-bg);
                transition: all var(--t-s);
            }

                .btn-cancel-link:hover {
                    border-color: #c7d2fe;
                    color: var(--accent);
                    background: var(--accent-lighter);
                }

            /* ══════════════════════════════════════════
           RIGHT PANEL
        ══════════════════════════════════════════ */
            .info-panel {
                display: flex;
                flex-direction: column;
                gap: 16px;
                position: sticky;
                top: 24px;
            }

            .info-card {
                background: var(--card-bg);
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius-lg);
                box-shadow: var(--card-shadow);
                overflow: hidden;
            }

            .info-card-header {
                padding: 13px 18px;
                border-bottom: 1px solid var(--card-border);
                display: flex;
                align-items: center;
                gap: 9px;
                background: #fafbff;
            }

                .info-card-header i {
                    font-size: 13px;
                    color: var(--accent);
                }

            .info-card-title {
                font-family: var(--font-display);
                font-size: 13px;
                font-weight: 700;
                color: var(--text-primary);
            }

            .info-card-body {
                padding: 16px 18px;
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

            /* ── Live Preview ── */
            .preview-card {
                background: linear-gradient(135deg, var(--accent-lighter) 0%, #eef2ff 100%);
                border: 1.5px dashed #c7d2fe;
                border-radius: var(--radius);
                padding: 18px;
                display: flex;
                flex-direction: column;
                gap: 12px;
                transition: all var(--t);
            }

                .preview-card.has-data {
                    border-color: var(--accent);
                    border-style: solid;
                }

            .preview-card-top {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .preview-card-icon {
                width: 40px;
                height: 40px;
                border-radius: var(--radius);
                background: var(--accent-lighter);
                border: 1.5px solid #c7d2fe;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 17px;
                color: var(--accent);
                flex-shrink: 0;
                transition: all var(--t-s);
            }

            .preview-card.has-data .preview-card-icon {
                background: var(--accent);
                color: #fff;
                border-color: var(--accent);
            }

            .preview-name {
                font-family: var(--font-display);
                font-size: 14px;
                font-weight: 700;
                color: var(--text-primary);
                min-height: 20px;
                line-height: 1.3;
            }

                .preview-name.placeholder {
                    color: var(--text-muted);
                    font-weight: 400;
                    font-style: italic;
                    font-family: var(--font-body);
                }

            .preview-meta {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

            .preview-meta-row {
                display: flex;
                align-items: flex-start;
                gap: 7px;
                font-size: 12px;
                color: var(--text-muted);
                line-height: 1.4;
            }

                .preview-meta-row i {
                    font-size: 11px;
                    color: var(--accent);
                    width: 14px;
                    text-align: center;
                    flex-shrink: 0;
                    margin-top: 1px;
                }

                .preview-meta-row .val {
                    font-style: italic;
                    color: var(--text-muted);
                }

                    .preview-meta-row .val.filled {
                        font-style: normal;
                        color: var(--text-secondary);
                        font-weight: 500;
                    }

            /* ── Tips ── */
            .tip-item {
                display: flex;
                gap: 10px;
                align-items: flex-start;
            }

            .tip-dot {
                width: 24px;
                height: 24px;
                border-radius: var(--radius-sm);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                flex-shrink: 0;
                margin-top: 1px;
            }

                .tip-dot.blue {
                    background: var(--accent-lighter);
                    color: var(--accent);
                }

                .tip-dot.green {
                    background: #d1fae5;
                    color: #059669;
                }

                .tip-dot.amber {
                    background: #fef3c7;
                    color: #d97706;
                }

            .tip-text {
                font-size: 12.5px;
                color: var(--text-muted);
                line-height: 1.5;
            }

                .tip-text strong {
                    color: var(--text-secondary);
                    font-weight: 700;
                }

            /* Required note */
            .required-note {
                background: var(--card-bg);
                border: 1.5px solid var(--card-border);
                border-radius: var(--radius);
                padding: 12px 16px;
                font-size: 12.5px;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                gap: 8px;
            }

            @@media (max-width: 900px) {
                .create-layout {
                    grid-template-columns: 1fr;
                }

                .info-panel {
                    position: static;
                }
            }
    </style>
}

<!-- ═══ Page Header ═══ -->
<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Şube Ekle</h1>
        <p class="page-desc">Sisteme yeni bir şube kaydı oluşturun.</p>
    </div>
    <a href="/Branch/Index" class="btn-cancel-link">
        <i class="fa-solid fa-arrow-left"></i> Şube Listesi
    </a>
</div>

<!-- ═══ Create Layout ═══ -->
<div class="create-layout">

    <!-- Sol: Form -->
    <div>
        <form method="post" id="branchForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-card">

                <!-- Header -->
                <div class="form-card-header">
                    <div class="form-card-header-icon">
                        <i class="fa-solid fa-building-circle-arrow-right"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Şube Bilgileri</div>
                        <div class="form-card-subtitle">Aşağıdaki alanları eksiksiz doldurun.</div>
                    </div>
                </div>

                <!-- Body -->
                <div class="form-card-body">

                    <div class="form-section-label">
                        <i class="fa-solid fa-circle-info" style="font-size:10px;color:var(--accent);"></i>
                        Temel Bilgiler
                    </div>

                    <!-- Şube Adı -->
                    <div class="form-group">
                        <label class="form-label" for="BranchName">
                            <i class="fa-solid fa-building"></i>
                            Şube Adı
                            <span class="required-dot"></span>
                        </label>
                        <div class="input-icon-wrap">
                            <input asp-for="BranchName"
                                   id="BranchName"
                                   class="form-input"
                                   placeholder="ör. İstanbul Havalimanı Şubesi"
                                   maxlength="100"
                                   oninput="updatePreview(); countChars(this,'nameCounter',100)"
                                   autocomplete="off" />
                            <i class="input-icon fa-solid fa-building"></i>
                        </div>
                        <div class="char-counter" id="nameCounter">0 / 100</div>
                        <span asp-validation-for="BranchName" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            Şubeyi tanımlayan açık ve anlaşılır bir isim girin.
                        </span>
                    </div>

                    <hr class="form-divider" />

                    <div class="form-section-label">
                        <i class="fa-solid fa-location-dot" style="font-size:10px;color:var(--accent);"></i>
                        Konum Bilgileri
                    </div>

                    <!-- Şehir -->
                    <div class="form-group">
                        <label class="form-label" for="City">
                            <i class="fa-solid fa-city"></i>
                            Şehir
                            <span class="required-dot"></span>
                        </label>
                        <div class="input-icon-wrap">
                            <input asp-for="City"
                                   id="City"
                                   class="form-input"
                                   placeholder="ör. İstanbul"
                                   maxlength="60"
                                   list="cityList"
                                   oninput="updatePreview(); countChars(this,'cityCounter',60)"
                                   autocomplete="off" />
                            <i class="input-icon fa-solid fa-city"></i>
                        </div>
                        <datalist id="cityList">
                            <option value="Adana" />
                            <option value="Ankara" />
                            <option value="Antalya" />
                            <option value="Ardahan" />
                            <option value="Bursa" />
                            <option value="Diyarbakır" />
                            <option value="Eskişehir" />
                            <option value="Gaziantep" />
                            <option value="İstanbul" />
                            <option value="İzmir" />
                            <option value="Kayseri" />
                            <option value="Konya" />
                            <option value="Mersin" />
                            <option value="Samsun" />
                            <option value="Trabzon" />
                        </datalist>
                        <div class="char-counter" id="cityCounter">0 / 60</div>
                        <span asp-validation-for="City" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                    </div>

                    <!-- Adres -->
                    <div class="form-group">
                        <label class="form-label" for="Address">
                            <i class="fa-solid fa-location-dot"></i>
                            Adres
                        </label>
                        <div class="input-icon-wrap">
                            <textarea asp-for="Address"
                                      id="Address"
                                      class="form-input"
                                      rows="3"
                                      placeholder="ör. Atatürk Mah. Havalimanı Cad. No:1 Arnavutköy, İstanbul"
                                      maxlength="300"
                                      oninput="updatePreview(); countChars(this,'addrCounter',300)"></textarea>
                            <i class="input-icon top fa-solid fa-location-dot"></i>
                        </div>
                        <div class="char-counter" id="addrCounter">0 / 300</div>
                        <span asp-validation-for="Address" class="field-error">
                            @*<i class="fa-solid fa-circle-exclamation"></i>*@
                        </span>
                        <span class="field-hint">
                            <i class="fa-solid fa-circle-info"></i>
                            İlçe ve mahalle bilgisi dahil tam adresi girin.
                        </span>
                    </div>

                </div>

                <!-- Footer -->
                <div class="form-card-footer">
                    <a href="/Branch/Index" class="btn-cancel-link">
                        <i class="fa-solid fa-xmark"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Şubeyi Kaydet
                    </button>
                </div>

            </div>
        </form>
    </div>

    <!-- Sağ: Info Panel -->
    <div class="info-panel">

        <!-- Canlı Önizleme -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-eye"></i>
                <div class="info-card-title">Canlı Önizleme</div>
            </div>
            <div class="info-card-body">
                <div class="preview-card" id="previewCard">
                    <div class="preview-card-top">
                        <div class="preview-card-icon">
                            <i class="fa-solid fa-building"></i>
                        </div>
                        <div id="previewName" class="preview-name placeholder">Şube adı girilmedi…</div>
                    </div>
                    <div class="preview-meta">
                        <div class="preview-meta-row">
                            <i class="fa-solid fa-city"></i>
                            <span class="val" id="previewCity">Şehir girilmedi</span>
                        </div>
                        <div class="preview-meta-row">
                            <i class="fa-solid fa-location-dot"></i>
                            <span class="val" id="previewAddress">Adres girilmedi</span>
                        </div>
                    </div>
                </div>
                <p style="font-size:11.5px;color:var(--text-muted);text-align:center;margin:0;">
                    Formu doldurdukça önizleme güncellenir.
                </p>
            </div>
        </div>

        <!-- İpuçları -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-lightbulb"></i>
                <div class="info-card-title">İpuçları</div>
            </div>
            <div class="info-card-body">
                <div class="tip-item">
                    <div class="tip-dot blue"><i class="fa-solid fa-building"></i></div>
                    <div class="tip-text">
                        <strong>Şube Adı</strong> benzersiz ve tanımlayıcı olmalıdır. "İstanbul Havalimanı Şubesi" gibi konum içeren isimler tercih edilir.
                    </div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot green"><i class="fa-solid fa-city"></i></div>
                    <div class="tip-text">
                        <strong>Şehir</strong> alanında Türkçe karakter kullanın. Sistem şehre göre filtreleme yapar.
                    </div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot amber"><i class="fa-solid fa-location-dot"></i></div>
                    <div class="tip-text">
                        <strong>Adres</strong> opsiyoneldir ancak müşteri iletişimi için tam adres girilmesi önerilir.
                    </div>
                </div>
            </div>
        </div>

        <!-- Zorunlu Alan Notu -->
        <div class="required-note">
            <span class="required-dot"></span>
            işaretli alanlar zorunludur.
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function updatePreview() {
            const name = document.getElementById('BranchName').value.trim();
            const city = document.getElementById('City').value.trim();
            const address = document.getElementById('Address').value.trim();

            const card = document.getElementById('previewCard');
            const pName = document.getElementById('previewName');
            const pCity = document.getElementById('previewCity');
            const pAddress = document.getElementById('previewAddress');

            const hasData = name || city || address;
            card.classList.toggle('has-data', !!hasData);

            if (name) {
                pName.textContent = name;
                pName.classList.remove('placeholder');
            } else {
                pName.textContent = 'Şube adı girilmedi…';
                pName.classList.add('placeholder');
            }

            pCity.textContent = city || 'Şehir girilmedi';
            pCity.classList.toggle('filled', !!city);

            const addrText = address ? (address.length > 60 ? address.substring(0, 57) + '…' : address) : 'Adres girilmedi';
            pAddress.textContent = addrText;
            pAddress.classList.toggle('filled', !!address);
        }

        function countChars(el, counterId, max) {
            const len = el.value.length;
            const counter = document.getElementById(counterId);
            counter.textContent = `${len} / ${max}`;
            counter.className = 'char-counter';
            if (len > max * 0.85) counter.classList.add('warn');
            if (len > max * 0.95) counter.classList.add('danger');
        }

        document.getElementById('branchForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
        });

        document.querySelectorAll('.form-input').forEach(input => {
            input.addEventListener('focus', () => {
                const icon = input.closest('.form-group')?.querySelector('.form-label i');
                if (icon) icon.style.color = 'var(--accent)';
            });
            input.addEventListener('blur', () => {
                const icon = input.closest('.form-group')?.querySelector('.form-label i');
                if (icon) icon.style.color = '';
            });
        });

        document.addEventListener('DOMContentLoaded', () => {
            updatePreview();
            const nameEl = document.getElementById('BranchName');
            const cityEl = document.getElementById('City');
            const addrEl = document.getElementById('Address');
            if (nameEl.value) countChars(nameEl, 'nameCounter', 100);
            if (cityEl.value) countChars(cityEl, 'cityCounter', 60);
            if (addrEl.value) countChars(addrEl, 'addrCounter', 300);
        });
    </script>
}
