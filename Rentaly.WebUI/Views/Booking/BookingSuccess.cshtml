
@{
    Layout = null;
}

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zxx">

@await Component.InvokeAsync("_DefaultHead");

<body>
    <div id="wrapper">

        <div id="de-preloader"></div>
        @await Component.InvokeAsync("_DefaultHeader")

        <div class="no-bottom no-top" id="content">
            <div id="top"></div>

            <section id="subheader" class="jarallax text-light">
                <img src="/RentalyTema/images/background/subheader.jpg" class="jarallax-img" alt="">
                <div class="center-y relative text-center">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-12 text-center">
                                <h1>Rezervasyon Tamamlandı</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="no-top no-bottom" style="background:#f8f9fa;">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-lg-7 text-center" style="padding:80px 20px;">

                            <!-- Animasyonlu Başarı İkonu -->
                            <div style="position:relative;width:120px;height:120px;margin:0 auto 32px;">
                                <div style="width:120px;height:120px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 32px rgba(16,185,129,0.25);animation:pulse 2s infinite;">
                                    <i class="fa fa-check" style="font-size:52px;color:#059669;"></i>
                                </div>
                            </div>

                            <h2 style="font-size:32px;font-weight:800;color:#1a1a2e;margin-bottom:12px;">
                                Rezervasyonunuz Alındı! 🎉
                            </h2>

                            <p style="font-size:16px;color:#6b7280;line-height:1.8;margin-bottom:36px;">
                                Rezervasyon talebiniz başarıyla oluşturuldu.<br>
                                Ekibimiz talebinizi en kısa sürede inceleyerek<br>
                                sizinle iletişime geçecektir.
                            </p>

                            <!-- Bilgi Kutuları -->
                            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px;">

                                <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:20px 16px;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                                    <div style="width:44px;height:44px;background:#d1fae5;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                                        <i class="fa fa-clock-o" style="font-size:18px;color:#059669;"></i>
                                    </div>
                                    <div style="font-size:13px;font-weight:700;color:#1a1a2e;">Onay Süresi</div>
                                    <div style="font-size:12px;color:#6b7280;margin-top:4px;">1-2 iş saati</div>
                                </div>

                                <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:20px 16px;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                                    <div style="width:44px;height:44px;background:#dbeafe;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                                        <i class="fa fa-envelope" style="font-size:18px;color:#2563eb;"></i>
                                    </div>
                                    <div style="font-size:13px;font-weight:700;color:#1a1a2e;">Bildirim</div>
                                    <div style="font-size:12px;color:#6b7280;margin-top:4px;">E-posta ile</div>
                                </div>

                                <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:20px 16px;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                                    <div style="width:44px;height:44px;background:#fef3c7;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                                        <i class="fa fa-phone" style="font-size:18px;color:#d97706;"></i>
                                    </div>
                                    <div style="font-size:13px;font-weight:700;color:#1a1a2e;">Destek</div>
                                    <div style="font-size:12px;color:#6b7280;margin-top:4px;">7/24 hizmet</div>
                                </div>

                            </div>

                            <!-- Durum Bilgisi -->
                            <div style="background:#fff;border:1px solid #bbf7d0;border-radius:12px;padding:18px 24px;margin-bottom:36px;display:flex;align-items:center;gap:14px;text-align:left;">
                                <div style="width:10px;height:10px;background:#10b981;border-radius:50%;flex-shrink:0;animation:blink 1.5s infinite;"></div>
                                <div>
                                    <div style="font-size:14px;font-weight:700;color:#1a1a2e;">Rezervasyon Durumu: Beklemede</div>
                                    <div style="font-size:13px;color:#6b7280;margin-top:2px;">Admin onayından sonra rezervasyonunuz aktif hale gelecektir.</div>
                                </div>
                            </div>

                            <!-- Butonlar -->
                            <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
                                <a href="/Default/CarList" class="btn-main">
                                    <i class="fa fa-car"></i> Araçlara Dön
                                </a>
                                <a href="/" style="display:inline-flex;align-items:center;gap:8px;padding:12px 28px;border:2px solid #e5e7eb;border-radius:8px;font-weight:700;color:#374151;text-decoration:none;background:#fff;transition:all 0.2s;">
                                    <i class="fa fa-home"></i> Ana Sayfa
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            </section>

        </div>

        <a href="#" id="back-to-top"></a>
        @await Component.InvokeAsync("_DefaultFooter")
    </div>

    <script src="/RentalyTema/js/plugins.js"></script>
    <script src="/RentalyTema/js/designesia.js"></script>

    <style>
        @@keyframes pulse {
            0% {
                box-shadow: 0 8px 32px rgba(16,185,129,0.25);
            }

            50% {
                box-shadow: 0 8px 48px rgba(16,185,129,0.50);
            }

            100% {
                box-shadow: 0 8px 32px rgba(16,185,129,0.25);
            }
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }
    </style>

</body>
</html>
