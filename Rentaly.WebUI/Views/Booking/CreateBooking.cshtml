@{
    Layout = null;

    var car = ViewBag.Car as Rentaly.EntityLayer.Entities.Car;
    var pickupBranch = ViewBag.PickupBranch as string;
    var returnBranch = ViewBag.ReturnBranch as string;
    var pickupDT = (DateTime)ViewBag.PickupDate;
    var returnDT = (DateTime)ViewBag.ReturnDate;
    var days = (int)ViewBag.Days;
    var totalPrice = (decimal)ViewBag.TotalPrice;
}

<!DOCTYPE html>
<html lang="zxx">

@await Component.InvokeAsync("_DefaultHead");

<body>
    <div id="wrapper">

        <div id="de-preloader"></div>
        @await Component.InvokeAsync("_DefaultHeader")

        <div class="no-bottom no-top" id="content">
            <div id="top"></div>

            <!-- Subheader -->
            <section id="subheader" class="jarallax text-light">
                <img src="/RentalyTema/images/background/subheader.jpg" class="jarallax-img" alt="">
                <div class="center-y relative text-center">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-12 text-center">
                                <h1>Rezervasyon</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section id="section-hero" aria-label="section" class="no-top" data-bgcolor="#121212">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-lg-12 mt-80 sm-mt-0">
                            <div class="spacer-single sm-hide"></div>

                            <div id="booking_form_wrap" class="padding40 rounded-5 shadow-soft" data-bgcolor="#ffffff">

                                <form asp-controller="Booking" asp-action="CreateBooking" method="post">
                                    @Html.AntiForgeryToken()

                                    <!-- Gizli alanlar — CarDetail'den gelenler -->
                                    <input type="hidden" name="carId" value="@car?.CarId" />
                                    <input type="hidden" name="pickupBranchId" value="@ViewBag.PickupBranchId" />
                                    <input type="hidden" name="returnBranchId" value="@ViewBag.ReturnBranchId" />
                                    <input type="hidden" name="pickupDate" value="@pickupDT.ToString("yyyy-MM-dd HH:mm")" />
                                    <input type="hidden" name="returnDate" value="@returnDT.ToString("yyyy-MM-dd HH:mm")" />
                                    <input type="hidden" name="totalPrice" value="@totalPrice" />

                                    <div class="row g-4">

                                        <!-- ══ SOL: Araç Özeti ══ -->
                                        <div class="col-lg-6">
                                            <h4>Rezervasyon Özeti</h4>

                                            <!-- Araç Kutusu -->
                                            <div style="display:flex;align-items:center;gap:16px;background:#f8f9fa;border:1px solid #e5e7eb;border-radius:12px;padding:16px;margin-bottom:20px;">
                                                @if (!string.IsNullOrEmpty(car?.ImageUrl))
                                                {
                                                    <img src="@car.ImageUrl" alt="@car.Brand?.BrandName"
                                                         style="width:100px;height:70px;object-fit:cover;border-radius:8px;flex-shrink:0;" />
                                                }
                                                else
                                                {
                                                    <div style="width:100px;height:70px;background:#e8efff;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                                        <i class="fa fa-car" style="font-size:28px;color:#6b7280;opacity:0.4;"></i>
                                                    </div>
                                                }
                                                <div>
                                                    <div style="font-size:16px;font-weight:800;color:#1a1a2e;">
                                                        @car?.Brand?.BrandName @car?.CarModel?.ModelName
                                                    </div>
                                                    <div style="font-size:13px;color:#6b7280;margin-top:4px;">
                                                        @car?.Year · @car?.FuelType · @car?.SeatCount Kişilik
                                                    </div>
                                                    <div style="font-size:15px;font-weight:700;color:#16a34a;margin-top:4px;">
                                                        @car?.DailyPrice.ToString("N0") ₺ / gün
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Kiralama Detayları -->
                                            <table style="width:100%;border-collapse:collapse;">
                                                <tr style="border-bottom:1px solid #f0f0f0;">
                                                    <td style="padding:10px 0;color:#9ca3af;font-size:14px;">Alış Şubesi</td>
                                                    <td style="padding:10px 0;font-weight:700;font-size:14px;color:#1a1a2e;">@pickupBranch</td>
                                                </tr>
                                                <tr style="border-bottom:1px solid #f0f0f0;">
                                                    <td style="padding:10px 0;color:#9ca3af;font-size:14px;">Dönüş Şubesi</td>
                                                    <td style="padding:10px 0;font-weight:700;font-size:14px;color:#1a1a2e;">@returnBranch</td>
                                                </tr>
                                                <tr style="border-bottom:1px solid #f0f0f0;">
                                                    <td style="padding:10px 0;color:#9ca3af;font-size:14px;">Alış Tarihi</td>
                                                    <td style="padding:10px 0;font-weight:700;font-size:14px;color:#1a1a2e;">@pickupDT.ToString("dd MMM yyyy HH:mm")</td>
                                                </tr>
                                                <tr style="border-bottom:1px solid #f0f0f0;">
                                                    <td style="padding:10px 0;color:#9ca3af;font-size:14px;">Dönüş Tarihi</td>
                                                    <td style="padding:10px 0;font-weight:700;font-size:14px;color:#1a1a2e;">@returnDT.ToString("dd MMM yyyy HH:mm")</td>
                                                </tr>
                                                <tr style="border-bottom:1px solid #f0f0f0;">
                                                    <td style="padding:10px 0;color:#9ca3af;font-size:14px;">Kiralama Süresi</td>
                                                    <td style="padding:10px 0;font-weight:700;font-size:14px;color:#1a1a2e;">@days Gün</td>
                                                </tr>
                                                <tr>
                                                    <td style="padding:10px 0;color:#9ca3af;font-size:14px;">Toplam Tutar</td>
                                                    <td style="padding:10px 0;font-weight:800;font-size:18px;color:#16a34a;">@totalPrice.ToString("N0") ₺</td>
                                                </tr>
                                            </table>
                                        </div>

                                        <!-- ══ SAĞ: Müşteri Bilgileri ══ -->
                                        <div class="col-lg-6">
                                            <h4>Kişisel Bilgileriniz</h4>
                                            <div class="row g-3">

                                                <div class="col-lg-6">
                                                    <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;display:block;">Ad <span style="color:red;">*</span></label>
                                                    <input type="text" name="name" class="form-control"
                                                           placeholder="Adınız" required
                                                           style="height:48px;border-radius:8px;border:1px solid #ddd;font-size:14px;" />
                                                </div>

                                                <div class="col-lg-6">
                                                    <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;display:block;">Soyad <span style="color:red;">*</span></label>
                                                    <input type="text" name="surname" class="form-control"
                                                           placeholder="Soyadınız" required
                                                           style="height:48px;border-radius:8px;border:1px solid #ddd;font-size:14px;" />
                                                </div>

                                                <div class="col-lg-6">
                                                    <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;display:block;">E-posta <span style="color:red;">*</span></label>
                                                    <input type="email" name="email" class="form-control"
                                                           placeholder="E-posta adresiniz" required
                                                           style="height:48px;border-radius:8px;border:1px solid #ddd;font-size:14px;" />
                                                </div>

                                                <div class="col-lg-6">
                                                    <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;display:block;">Telefon <span style="color:red;">*</span></label>
                                                    <input type="tel" name="phone" class="form-control"
                                                           placeholder="05XX XXX XX XX" required
                                                           style="height:48px;border-radius:8px;border:1px solid #ddd;font-size:14px;" />
                                                </div>

                                                <div class="col-lg-12">
                                                    <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;display:block;">TC Kimlik No <span style="color:red;">*</span></label>
                                                    <input type="text" name="identityNumber" class="form-control"
                                                           placeholder="TC Kimlik numaranız" required maxlength="11"
                                                           style="height:48px;border-radius:8px;border:1px solid #ddd;font-size:14px;" />
                                                </div>

                                                <div class="col-lg-6">
                                                    <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;display:block;">Ehliyet No <span style="color:red;">*</span></label>
                                                    <input type="text" name="drivingLicenseNumber" class="form-control"
                                                           placeholder="Ehliyet numaranız" required
                                                           style="height:48px;border-radius:8px;border:1px solid #ddd;font-size:14px;" />
                                                </div>

                                                <div class="col-lg-6">
                                                    <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;display:block;">Ehliyet Tarihi <span style="color:red;">*</span></label>
                                                    <input type="date" name="drivingLicenseDate" class="form-control"
                                                           required
                                                           style="height:48px;border-radius:8px;border:1px solid #ddd;font-size:14px;" />
                                                </div>

                                                <!-- Toplam Tutar Özeti -->
                                                <div class="col-lg-12">
                                                    <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:14px 18px;margin-top:8px;">
                                                        <div style="display:flex;justify-content:space-between;align-items:center;">
                                                            <span style="font-size:14px;color:#6b7280;">@days Gün × @car?.DailyPrice.ToString("N0") ₺</span>
                                                            <span style="font-size:22px;font-weight:800;color:#16a34a;">@totalPrice.ToString("N0") ₺</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Submit -->
                                                <div class="col-lg-12">
                                                    <button type="submit" class="btn-main btn-fullwidth"
                                                            style="height:52px;font-size:15px;font-weight:700;border-radius:10px;letter-spacing:0.5px;">
                                                        <i class="fa fa-calendar-check"></i> Rezervasyonu Tamamla
                                                    </button>
                                                </div>

                                            </div>
                                        </div>

                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </div>

        <a href="#" id="back-to-top"></a>
        @await Component.InvokeAsync("_DefaultFooter")
    </div>

    <script src="/RentalyTema/js/plugins.js"></script>
    <script src="/RentalyTema/js/designesia.js"></script>
</body>
</html>
