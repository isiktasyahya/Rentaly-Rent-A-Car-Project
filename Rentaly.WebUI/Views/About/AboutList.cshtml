@model List<Rentaly.EntityLayer.Entities.About>
@{
    ViewData["Title"] = "AboutList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <style>
        /* ══════════════════════════════════════════
           ABOUT LIST — Indigo Daylight Theme
        ══════════════════════════════════════════ */

        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 28px;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.02em;
            line-height: 1.2;
        }

        .page-desc {
            font-size: 13.5px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        /* ── Stats ── */
        .stat-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
            margin-bottom: 28px;
        }

        .s-card {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            padding: 18px 20px;
            box-shadow: var(--card-shadow);
            display: flex;
            align-items: center;
            gap: 14px;
            transition: all var(--t);
            position: relative;
            overflow: hidden;
        }

            .s-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                border-radius: var(--radius-lg) var(--radius-lg) 0 0;
                opacity: 0;
                transition: opacity var(--t);
            }

            .s-card.indigo::before {
                background: var(--accent);
            }

            .s-card.emerald::before {
                background: var(--emerald);
            }

            .s-card.amber::before {
                background: var(--amber);
            }

            .s-card:hover {
                box-shadow: var(--card-shadow-hover);
                transform: translateY(-2px);
                border-color: #c7d2fe;
            }

                .s-card:hover::before {
                    opacity: 1;
                }

        .s-ico {
            width: 46px;
            height: 46px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
            flex-shrink: 0;
        }

        .s-val {
            font-family: var(--font-display);
            font-size: 26px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1;
            letter-spacing: -0.02em;
        }

        .s-lbl {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
            font-weight: 500;
        }

        /* ── Toolbar ── */
        .toolbar {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            padding: 13px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            box-shadow: var(--card-shadow);
            margin-bottom: 22px;
        }

        .sw {
            position: relative;
            flex: 1;
            min-width: 220px;
        }

            .sw i {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 13px;
                pointer-events: none;
            }

        .s-input {
            width: 100%;
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-sm);
            padding: 9px 13px 9px 38px;
            font-size: 13.5px;
            font-family: var(--font-body);
            color: var(--text-primary);
            background: var(--page-bg);
            outline: none;
            transition: all var(--t-s);
        }

            .s-input:focus {
                border-color: var(--accent);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(79,70,229,0.10);
            }

            .s-input::placeholder {
                color: var(--text-muted);
            }

        .btn-reset {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 14px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            font-family: var(--font-body);
            cursor: pointer;
            border: 1.5px solid var(--card-border);
            background: var(--page-bg);
            color: var(--text-secondary);
            transition: all var(--t-s);
            white-space: nowrap;
        }

            .btn-reset:hover {
                background: var(--accent-lighter);
                border-color: #c7d2fe;
                color: var(--accent);
            }

        .btn-add {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 9px 20px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            font-family: var(--font-body);
            background: var(--accent);
            color: #fff;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all var(--t-s);
            box-shadow: 0 2px 8px rgba(79,70,229,0.25);
            white-space: nowrap;
        }

            .btn-add:hover {
                background: var(--accent-hover);
                box-shadow: 0 4px 16px rgba(79,70,229,0.35);
                transform: translateY(-1px);
                color: #fff;
            }

        /* ══ ABOUT CARDS ══ */
        .about-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .about-card {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--card-shadow);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: all var(--t);
            position: relative;
        }

            .about-card:hover {
                box-shadow: var(--card-shadow-hover);
                transform: translateY(-3px);
                border-color: #c7d2fe;
            }

        /* Dekoratif üst şerit */
        .about-card-stripe {
            height: 5px;
            background: linear-gradient(90deg, var(--accent) 0%, #818cf8 100%);
            flex-shrink: 0;
        }

        /* Numaralı header */
        .about-card-header {
            padding: 20px 22px 16px;
            display: flex;
            align-items: flex-start;
            gap: 16px;
            border-bottom: 1px solid var(--card-border);
        }

        .about-num {
            width: 48px;
            height: 48px;
            border-radius: var(--radius);
            background: var(--accent);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 18px;
            font-weight: 800;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(79,70,229,0.30);
            transition: all var(--t-s);
        }

        .about-card:hover .about-num {
            transform: scale(1.06);
            box-shadow: 0 6px 20px rgba(79,70,229,0.40);
        }

        .about-id-badge {
            display: inline-flex;
            align-items: center;
            background: var(--accent-lighter);
            color: var(--accent-text);
            border: 1px solid #c7d2fe;
            font-size: 10.5px;
            font-weight: 700;
            padding: 2px 9px;
            border-radius: 99px;
            font-family: var(--font-display);
            margin-bottom: 6px;
        }

        .about-card-title {
            font-family: var(--font-display);
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.3;
        }

        /* Body */
        .about-card-body {
            padding: 18px 22px;
            flex: 1;
            position: relative;
        }

        .about-quote {
            position: absolute;
            top: 14px;
            right: 18px;
            font-size: 48px;
            color: var(--accent-lighter);
            font-family: Georgia, serif;
            line-height: 1;
            pointer-events: none;
            user-select: none;
        }

        .about-desc {
            font-size: 13.5px;
            color: var(--text-secondary);
            line-height: 1.75;
            position: relative;
            z-index: 1;
        }

        .about-desc-fade { /* uzun metinler için gradient fade */
            display: -webkit-box;
            -webkit-line-clamp: 5;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .about-word-count {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin-top: 12px;
            font-size: 11.5px;
            color: var(--text-muted);
            background: var(--page-bg);
            border: 1px solid var(--card-border);
            padding: 4px 10px;
            border-radius: 99px;
        }

        /* Footer */
        .about-card-footer {
            padding: 13px 18px;
            border-top: 1px solid var(--card-border);
            background: #fafbff;
            display: flex;
            gap: 8px;
        }

        /* Action buttons */
        .tbl-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 7px 13px;
            border-radius: var(--radius-sm);
            font-size: 12.5px;
            font-weight: 600;
            font-family: var(--font-body);
            cursor: pointer;
            transition: all var(--t-s);
            border: 1.5px solid transparent;
            text-decoration: none;
            white-space: nowrap;
        }

        .tbl-btn-edit {
            background: #fef3c7;
            color: #92400e;
            border-color: #fde68a;
            flex: 1;
            justify-content: center;
        }

            .tbl-btn-edit:hover {
                background: #f59e0b;
                color: #fff;
                border-color: #f59e0b;
            }

        .tbl-btn-delete {
            background: #fff1f2;
            color: #e11d48;
            border-color: #fecdd3;
            padding: 7px 11px;
        }

            .tbl-btn-delete:hover {
                background: #f43f5e;
                color: #fff;
                border-color: #f43f5e;
            }

        /* Empty */
        .empty-state {
            padding: 72px 20px;
            text-align: center;
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--card-shadow);
        }

        .empty-icon {
            width: 80px;
            height: 80px;
            background: var(--accent-lighter);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            color: var(--accent);
            margin: 0 auto 20px;
            position: relative;
        }

            .empty-icon::after {
                content: '';
                position: absolute;
                inset: -6px;
                border-radius: 50%;
                border: 2px dashed #c7d2fe;
                animation: spin 12s linear infinite;
            }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .empty-title {
            font-family: var(--font-display);
            font-size: 17px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        /* Delete Modal */
        .modal-content {
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius-lg);
            box-shadow: 0 8px 40px rgba(30,27,75,0.14);
        }

        .modal-header {
            border-bottom: 1px solid var(--card-border);
            padding: 16px 20px;
        }

        .modal-footer {
            border-top: 1px solid var(--card-border);
            padding: 14px 20px;
            gap: 8px;
            background: #fafbff;
        }

        .modal-title {
            font-family: var(--font-display);
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .btn-cancel {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 18px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            font-family: var(--font-body);
            background: var(--page-bg);
            color: var(--text-secondary);
            border: 1.5px solid var(--card-border);
            cursor: pointer;
            transition: all var(--t-s);
        }

            .btn-cancel:hover {
                background: var(--card-border);
            }

        .btn-confirm-delete {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: #f43f5e;
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 9px 22px;
            font-size: 13.5px;
            font-weight: 700;
            font-family: var(--font-body);
            cursor: pointer;
            transition: all var(--t-s);
            box-shadow: 0 2px 8px rgba(244,63,94,0.25);
        }

            .btn-confirm-delete:hover {
                background: #e11d48;
                transform: translateY(-1px);
            }

        /* Toast */
        .rc-toast {
            background: var(--card-bg);
            border: 1.5px solid var(--card-border);
            border-radius: var(--radius);
            box-shadow: 0 8px 32px rgba(30,27,75,0.14);
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13.5px;
            min-width: 260px;
            animation: toastIn 0.3s ease both;
        }

        @@keyframes toastIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Animasyonlar */
        .about-card {
            animation: fadeUp 0.35s cubic-bezier(0.4,0,0.2,1) both;
        }

            .about-card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .about-card:nth-child(2) {
                animation-delay: 0.10s;
            }

            .about-card:nth-child(3) {
                animation-delay: 0.15s;
            }

            .about-card:nth-child(4) {
                animation-delay: 0.20s;
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 640px) {
            .about-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Hakkımızda</h1>
        <p class="page-desc">Ana sayfada gösterilen hakkımızda içeriklerini yönetin.</p>
    </div>
    <a href="/About/CreateAbout/" class="btn-add">
        <i class="fa-solid fa-plus"></i> Yeni İçerik
    </a>
</div>

<!-- Stat Cards -->
<div class="stat-row">
    <div class="s-card indigo">
        <div class="s-ico" style="background:var(--accent-lighter);color:var(--accent);">
            <i class="fa-solid fa-building"></i>
        </div>
        <div>
            <div class="s-val">@Model.Count()</div>
            <div class="s-lbl">Toplam İçerik</div>
        </div>
    </div>
    <div class="s-card emerald">
        <div class="s-ico" style="background:#d1fae5;color:#059669;">
            <i class="fa-solid fa-eye"></i>
        </div>
        <div>
            <div class="s-val" style="color:#059669;" id="statVisible">@Model.Count()</div>
            <div class="s-lbl">Gösterilen</div>
        </div>
    </div>
    <div class="s-card amber">
        <div class="s-ico" style="background:#fef3c7;color:#d97706;">
            <i class="fa-solid fa-align-left"></i>
        </div>
        <div>
            <div class="s-val" style="color:#d97706;font-size:18px;">
                @(Model.Any()
                    ? Model.Sum(a => (a.Decription ?? "").Split(' ').Length).ToString() + ""
                    : "0")
            </div>
            <div class="s-lbl">Toplam Kelime</div>
        </div>
    </div>
</div>

<!-- Toolbar -->
<div class="toolbar">
    <div class="sw">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" class="s-input" id="aboutSearch"
               placeholder="Başlık veya içerik ara…"
               oninput="filterAbouts()" />
    </div>
    <button class="btn-reset" onclick="clearSearch()">
        <i class="fa-solid fa-rotate-left"></i> Sıfırla
    </button>
</div>

<!-- Cards Grid -->
<div class="about-grid" id="aboutGrid">
    @{ int cardIdx = 1; }
    @foreach (var a in Model)
    {
        var wordCount = (a.Decription ?? "").Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries).Length;
        var charCount = (a.Decription ?? "").Length;

        <div class="about-card"
             data-id="@a.AboutId"
             data-title="@a.Title?.ToLower()"
             data-desc="@a.Decription?.ToLower()">

            <div class="about-card-stripe"></div>

            <div class="about-card-header">
                <div class="about-num">@cardIdx</div>
                <div style="flex:1;min-width:0;">
                    <div class="about-id-badge"># @a.AboutId</div>
                    <div class="about-card-title">@a.Title</div>
                </div>
            </div>

            <div class="about-card-body">
                <div class="about-quote">"</div>
                <div class="about-desc about-desc-fade">@a.Decription</div>
                <div>
                    <span class="about-word-count">
                        <i class="fa-solid fa-font" style="font-size:10px;color:var(--accent);"></i>
                        @wordCount kelime · @charCount karakter
                    </span>
                </div>
            </div>

            <div class="about-card-footer">
                <a href="/About/UpdateAbout/@a.AboutId" class="tbl-btn tbl-btn-edit">
                    <i class="fa-solid fa-pen-to-square"></i> Düzenle
                </a>
                <a href="/About/DeleteAbout/@a.AboutId"
                   class="tbl-btn tbl-btn-delete"
                   onclick="return confirm('@a.Title kaydını silmek istediğinize emin misiniz?')">
                    <i class="fa-solid fa-trash-can"></i>
                </a>
            </div>
        </div>
        cardIdx++;
    }
</div>

<!-- Empty State -->
<div class="empty-state" id="emptyState" style="display:none;">
    <div class="empty-icon"><i class="fa-solid fa-building"></i></div>
    <div class="empty-title">İçerik Bulunamadı</div>
    <p style="font-size:13.5px;color:var(--text-muted);margin-bottom:18px;">Arama kriterinizle eşleşen içerik yok.</p>
    <button class="btn-add" onclick="clearSearch()">
        <i class="fa-solid fa-rotate-left"></i> Aramayı Temizle
    </button>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content">
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:36px;height:36px;background:#fff1f2;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;color:#f43f5e;font-size:15px;">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                    <h5 class="modal-title">İçeriği Sil</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:22px;">
                <div style="display:flex;gap:14px;align-items:flex-start;">
                    <div style="width:48px;height:48px;background:#fff1f2;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#f43f5e;font-size:20px;flex-shrink:0;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div>
                        <p style="margin:0;font-size:14.5px;color:var(--text-primary);line-height:1.5;">
                            <strong id="deleteAboutTitle">bu içeriği</strong> silmek istediğinizden emin misiniz?
                        </p>
                        <p style="margin:6px 0 0;font-size:13px;color:var(--text-muted);">Bu işlem geri alınamaz. Ana sayfa etkilenebilir.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark"></i> Vazgeç
                </button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteAboutId" name="id" />
                    <button type="submit" class="btn-confirm-delete">
                        <i class="fa-solid fa-trash-can"></i> Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

@section Scripts {
    <script>
    function filterAbouts() {
        const q = document.getElementById('aboutSearch').value.toLowerCase().trim();
        const cards = [...document.querySelectorAll('#aboutGrid .about-card')];
        let visible = 0;
        cards.forEach(c => {
            const show = !q || (c.dataset.title||'').includes(q) || (c.dataset.desc||'').includes(q) || c.dataset.id.includes(q);
            c.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('statVisible').textContent = visible;
        document.getElementById('emptyState').style.display = visible === 0 ? 'block' : 'none';
    }

    function clearSearch() {
        document.getElementById('aboutSearch').value = '';
        filterAbouts();
    }

    function openDeleteModal(id, title) {
        document.getElementById('deleteAboutTitle').textContent = `"${title}"`;
        document.getElementById('deleteAboutId').value = id;
        document.getElementById('deleteForm').action = `/About/Delete/${id}`;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    function showToast(msg, type) {
        const icons  = { success: 'fa-check-circle', info: 'fa-circle-info', danger: 'fa-triangle-exclamation' };
        const colors = { success: '#10b981', info: 'var(--accent)', danger: '#f43f5e' };
        const wrap   = document.createElement('div');
        wrap.innerHTML = `<div class="rc-toast">
            <i class="fa-solid ${icons[type]||'fa-circle-info'}" style="font-size:16px;color:${colors[type]||'var(--accent)'};flex-shrink:0;"></i>
            <span style="flex:1;font-family:var(--font-body);">${msg}</span>
            <button onclick="this.closest('.rc-toast').remove()" style="border:none;background:none;color:var(--text-muted);cursor:pointer;font-size:13px;padding:0;">✕</button>
        </div>`;
        document.getElementById('toastContainer').appendChild(wrap);
        setTimeout(() => wrap.remove(), 4000);
    }

    document.addEventListener('DOMContentLoaded', () => {
        @if (TempData["Success"] != null) { <text>showToast('@TempData["Success"]', 'success');</text> }
        @if (TempData["Error"]   != null) { <text>showToast('@TempData["Error"]',   'danger');</text>  }
    });
    </script>
}


