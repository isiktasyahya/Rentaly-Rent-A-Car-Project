@model List<Rentaly.EntityLayer.Entities.Car>

<section id="section-cars">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-6 offset-lg-3 text-center">
                <h2>Araç Filomuz</h2>
                <p>
                    Konforlu, güvenli ve farklı ihtiyaçlara uygun geniş araç filomuz ile
                    yolculuklarınızı keyifli ve unutulmaz hale getiriyoruz.
                </p>
                <div class="spacer-20"></div>
            </div>

            <div id="items-carousel" class="owl-carousel wow fadeIn">

                @foreach (var item in Model)
                {
                    <div class="item">
                        <div class="de-item mb30 custom-car-card">

                            <!-- RESİM -->
                            <div class="d-img custom-img-box">
                                <img src="@item.ImageUrl" class="img-fluid custom-car-img" alt="">
                            </div>

                            <!-- İÇERİK -->
                            <div class="d-info">
                                <div class="d-text">

                                    <!-- BAŞLIK -->
                                    <h4 class="car-title">
                                        @item.Brand.BrandName @item.CarModel.ModelName
                                    </h4>

                                    <!-- FAVORİ -->
                                    <div class="d-item_like">
                                        <i class="fa fa-heart"></i>
                                        <span>@item.Kilometer</span>
                                    </div>

                                    <!-- ÖZELLİKLER -->
                                    <div class="d-atr-group">

                                        <span class="d-atr">
                                            <img src="/RentalyTema/images/icons/1-green.svg" alt="">
                                            @item.SeatCount
                                        </span>

                                        <span class="d-atr">
                                            <img src="/RentalyTema/images/icons/2-green.svg" alt="">
                                            @item.LuggageCount
                                        </span>

                                        <span class="d-atr">
                                            <img src="/RentalyTema/images/icons/3-green.svg" alt="">
                                            @item.Kilometer
                                        </span>

                                        <span class="d-atr">
                                            <img src="/RentalyTema/images/icons/4-green.svg" alt="">
                                            @item.FuelType
                                        </span>

                                    </div>

                                    <!-- FİYAT -->
                                    <div class="d-price custom-price-area">

                                        <div>
                                            <small>Günlük Kiralama Bedeli</small>
                                            <span>@item.DailyPrice ₺</span>
                                        </div>

                                        <a class="btn-main" href="/Car/CarDetail/@item.CarId/">Detay</a>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</section>


<style>

    /* kart genel yapı */
    .custom-car-card {
        border-radius: 18px;
        overflow: hidden;
        min-height: 430px;
        background: #fff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        padding: 0;
    }

    /* resim alanı */
    .custom-img-box {
        height: 220px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fff;
        padding: 10px;
    }

    /* TÜM ARAÇ FOTOĞRAFLARI AYNI BOY */
    .custom-car-img {
        width: 100%;
        height: 220px;
        object-fit: contain;
    }

    /* içerik */
    .d-info {
        padding: 18px;
    }

    .car-title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 20px;
        color: #0d1b4c;
    }

    .d-atr-group {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 15px;
        margin-bottom: 20px;
    }

    .d-atr {
        font-size: 22px;
        font-weight: 600;
        color: #0d1b4c;
    }

        .d-atr img {
            width: 20px;
            margin-right: 6px;
        }

    /* fiyat alanı */
    .custom-price-area {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
    }

        .custom-price-area small {
            display: block;
            color: #777;
            font-size: 18px;
        }

        .custom-price-area span {
            font-size: 42px;
            font-weight: 800;
            color: #0d1b4c;
        }

    .btn-main {
        padding: 14px 28px;
        border-radius: 10px;
        font-size: 18px;
        font-weight: 700;
    }
</style>