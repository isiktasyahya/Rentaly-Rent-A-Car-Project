@model List<Rentaly.EntityLayer.Entities.Testimonial>
<section id="section-testimonials" class="no-top no-bottom">
    <div class="container-fluid">
        <div class="row g-2 p-2 align-items-center">
            @foreach (var item in Model)
            {
                <div class="col-md-4">
                    <div class="de-image-text">
                        <div class="d-text">
                            <div class="d-quote id-color"><i class="fa fa-quote-right"></i></div>
                            <h4>@item.Title</h4>
                            <blockquote>
                               @item.Description
                                <span class="by">@item.NameSurname</span>
                            </blockquote>
                        </div>
                        <img src="@item.ImageUrl" class="img-fluid" alt="">
                    </div>
                </div>
            }


        </div>
    </div>
</section>